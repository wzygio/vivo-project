<![CDATA[]]></PageQuery>
</TableData>
<TableData name="SEARCH_RESTORE_YLD" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="txtID"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[M559]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdSpec"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbSubProdType"/>
<O>
<![CDATA[ESLC]]></O>
</Parameter>
<Parameter>
<Attributes name="txtWeek"/>
<O>
<![CDATA[3]]></O>
</Parameter>
<Parameter>
<Attributes name="dtDateTime"/>
<O>
<![CDATA[2025-03-03]]></O>
</Parameter>
<Parameter>
<Attributes name="txtMonth"/>
<O>
<![CDATA[2]]></O>
</Parameter>
<Parameter>
<Attributes name="txtDay"/>
<O>
<![CDATA[7]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
WITH TIME_TAB AS (
SELECT 'DAY' AS DATE_TYPE
       ,DATE_TIMEKEY AS DATE_VALUE
       ,ROW_NUMBER() OVER(ORDER BY DATE_TIMEKEY) AS RN
  FROM DWD_CALENDAR
 WHERE FACTORY = 'ARRAY'
   AND TIME_TYPE = 'DAY'
   AND DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   AND DATE_TIMEKEY > TO_CHAR(TO_DATE('${dtDateTime}','YYYY-MM-DD') - INTERVAL '${txtDay}DAY','YYYYMMDD')
--月周
UNION ALL
SELECT S.DATE_TYPE
      ,S.DATE_VALUE
      ,S.RN
  FROM(SELECT T.DATE_TYPE
             ,T.DATE_VALUE
             ,ROW_NUMBER() OVER(PARTITION BY T.DATE_TYPE ORDER BY T.DATE_VALUE DESC) AS RN
         FROM(-- 周(此处获取当前周之前的所有周)
              SELECT DISTINCT 'WEEK' AS DATE_TYPE
                    ,N.WEEK_TIMEKEY AS DATE_VALUE
                FROM DWD_CALENDAR N
               INNER JOIN(-- 当前日期所在周
                          SELECT WEEK_TIMEKEY
                            FROM DWD_CALENDAR
                           WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                             AND FACTORY = 'ARRAY'
                             AND TIME_TYPE = 'DAY'
                         ) M
                       ON M.WEEK_TIMEKEY >= N.WEEK_TIMEKEY -- 当前周往前推
               WHERE N.FACTORY = 'ARRAY'
                 AND N.TIME_TYPE = 'DAY'
               UNION ALL
               -- 月(此处获取当前月之前的所有月)
               SELECT DISTINCT 'MONTH' AS DATE_TYPE
                     ,N.MONTH_TIMEKEY AS DATE_VALUE
                 FROM DWD_CALENDAR N
                INNER JOIN(SELECT MONTH_TIMEKEY
                             FROM DWD_CALENDAR
                            WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                              AND FACTORY = 'ARRAY'
                              AND TIME_TYPE = 'DAY'
                           ) M
                        ON M.MONTH_TIMEKEY >= N.MONTH_TIMEKEY -- 当前月往前推
                WHERE N.FACTORY = 'ARRAY'
                  AND N.TIME_TYPE = 'DAY'
              ) T
      ) S
 WHERE RN <= (CASE DATE_TYPE WHEN 'MONTH' THEN CAST('${txtMonth}' AS INT) ELSE CAST('${txtWeek}' AS INT) END))
,DEFECT_CODE_INFO AS (
SELECT 	PANEL_ID
       ,PROD_ID
       ,RISK_FLAG
       ,SUB_PROD_TYPE
       ,FIRST_SHIP_DATE
       ,CASE WHEN SUBSTR(FIRST_DTL_GRADE,1,1)='C' AND (DTL_GRADE='S' OR DTL_GRADE IS NULL)
	         THEN FIRST_DEFECT_CODE
	         ELSE LAST_DFT_CODE 
	         END AS DEFECT_CODE 
FROM (
SELECT T.* 
      ,S.REASON_CODE AS LAST_DFT_CODE
      ,ROW_NUMBER() OVER (PARTITION BY T.PANEL_ID ORDER BY T.FIRST_SHIP_TIME DESC ) AS RN
FROM DWT_WAREHOUSING_PNL T 		 
  LEFT JOIN IMP_YLD_GRADE_FLAG G 
         ON T.DTL_GRADE=G.GRADE 
LEFT JOIN DWT_TST_PNL_SCRAP S
	   ON S.PANEL_ID = T.PANEL_ID
        AND S.S_LAST_FLAG = 'Y'
       AND T.DATE_TIMEKEY >= S.DATE_TIMEKEY 
        AND S.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' - INTERVAL '2 MONTH','YYYYMMDD')
        AND S.DATE_TIMEKEY <= TO_CHAR('${dtDateTime}'::TIMESTAMP + INTERVAL '2 MONTH' ,'YYYYMMDD')
	  AND (CASE WHEN T.PANEL_GRADE = 'S' OR T.PANEL_GRADE IS NULL THEN 'S' ELSE T.DTL_GRADE END) = (CASE WHEN S.GRADE = 'S' OR S.GRADE IS NULL THEN 'S' ELSE S.DTL_GRADE END)
WHERE T.LAST_FLAG = 'Y'
  AND T.DATE_TIMEKEY >=TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
  AND (T.PANEL_GRADE = 'S' OR (T.PANEL_GRADE = 'G' AND (G.GRADE_FLAG ='N' OR (T.DTL_GRADE = 'A1' AND T.FIRST_SHIP_DATE < '20221127' AND T.A1_SHIP_FLAG = 'N'))))	   
) R
WHERE R.RN=1)
SELECT T.DATE_TYPE
      ,T.DATE_VALUE
      ,A.PROD_CODE
      ,COALESCE(A.FACTORY,'未分责') AS FACTORY
      ,SUM(A.DFT_QTY) AS GROUP_DFT_TY
      ,SUM(CASE WHEN A.RISK_FLAG <> 'Y' THEN A.DFT_QTY ELSE 0 END) AS NOT_RISK_DFT_QTY 
  FROM TIME_TAB T
       LEFT JOIN 
       (SELECT 'MONTH' AS DATE_TYPE
		      ,W.MONTH_TIMEKEY AS DATE_VALUE
		      ,W.PROD_CODE
		      ,DECODE(G.FACTORY,'TP','TP','屏体','屏体',G.FACTORY) 
		      ,W.PANEL_ID
		      ,W.RISK_FLAG 
		      ,1 AS DFT_QTY
		  FROM DWS_DFT_WAREHOUSING_D W
		       LEFT JOIN IMP_CT_DFT_GROUP G
		              ON W.DEFECT_CODE = G.DEFECT_CODE
		 WHERE W.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
		   AND W.DATE_TIMEKEY <= '${dtDateTime}'
		   --AND P.PRODUCTCODE = 'D17'		   
             ${IF(LEN(cmcbProdCode)=0,"","AND W.PROD_CODE IN ('"+cmcbProdCode+"')")}
		   ${IF(LEN(cmcbProdSpec)=0,"","AND W.PROD_ID IN ('"+cmcbProdSpec+"')")}
		   ${IF(LEN(cmcbSubProdType)=0,"","AND W.SUB_PROD_TYPE IN ('"+cmcbSubProdType+"')")}
		   ${IF(LEN(txtID) = 0,"", "AND SUBSTR(S.PANEL_ID,1,11) IN ('" + txtID + "')" )} 
		 GROUP BY  W.MONTH_TIMEKEY
			      ,W.PROD_CODE
			      ,G.FACTORY 
			      ,W.PANEL_ID
		           ,W.RISK_FLAG
		 UNION ALL 
		 SELECT 'WEEK' AS DATE_TYPE
		      ,W.WEEK_TIMEKEY AS DATE_VALUE
		      ,W.PROD_CODE
		      ,DECODE(G.FACTORY,'TP','TP','屏体','屏体',G.FACTORY) 
		      ,W.PANEL_ID
		      ,W.RISK_FLAG 
		      ,1 AS DFT_QTY
		  FROM DWS_DFT_WAREHOUSING_D W
		       LEFT JOIN IMP_CT_DFT_GROUP G
		              ON W.DEFECT_CODE = G.DEFECT_CODE		
		 WHERE W.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtWeek} WEEK' ,'YYYYMMDD')
		   AND W.DATE_TIMEKEY <= '${dtDateTime}'
             ${IF(LEN(cmcbProdCode)=0,"","AND W.PROD_CODE IN ('"+cmcbProdCode+"')")}
		   ${IF(LEN(cmcbProdSpec)=0,"","AND W.PROD_ID IN ('"+cmcbProdSpec+"')")}
		   ${IF(LEN(cmcbSubProdType)=0,"","AND W.SUB_PROD_TYPE IN ('"+cmcbSubProdType+"')")}
		   ${IF(LEN(txtID) = 0,"", "AND SUBSTR(S.PANEL_ID,1,11) IN ('" + txtID + "')" )} 
		 GROUP BY  W.WEEK_TIMEKEY 
			      ,W.PROD_CODE
			      ,G.FACTORY 
			      ,W.PANEL_ID
		           ,W.RISK_FLAG
		UNION ALL 
		SELECT 'DAY' AS DATE_TYPE
		      ,W.DATE_TIMEKEY AS DATE_VALUE
		      ,W.PROD_CODE
		      ,DECODE(G.FACTORY,'TP','TP','屏体','屏体',G.FACTORY) 
		      ,W.PANEL_ID
		      ,W.RISK_FLAG 
		      ,1 AS DFT_QTY
		  FROM DWS_DFT_WAREHOUSING_D W
		       LEFT JOIN IMP_CT_DFT_GROUP G
		              ON W.DEFECT_CODE = G.DEFECT_CODE   
		 WHERE W.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtDay} DAY' ,'YYYYMMDD')
		   AND W.DATE_TIMEKEY <= '${dtDateTime}'
             ${IF(LEN(cmcbProdCode)=0,"","AND W.PROD_CODE IN ('"+cmcbProdCode+"')")}
		   ${IF(LEN(cmcbProdSpec)=0,"","AND W.PROD_ID IN ('"+cmcbProdSpec+"')")}
		   ${IF(LEN(cmcbSubProdType)=0,"","AND W.SUB_PROD_TYPE IN ('"+cmcbSubProdType+"')")}
		   ${IF(LEN(txtID) = 0,"", "AND SUBSTR(S.PANEL_ID,1,11) IN ('" + txtID + "')" )} 
		 GROUP BY  W.DATE_TIMEKEY 
			      ,W.PROD_CODE
			      ,G.FACTORY 
			      ,W.PANEL_ID
		          ,W.RISK_FLAG
	    ) A
	   ON T.DATE_VALUE = A.DATE_VALUE
 --WHERE A.FACTORY IS NOT NULL
 GROUP BY T.DATE_TYPE
         ,T.DATE_VALUE
	     ,A.PROD_CODE
         ,A.FACTORY]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="SEARCH_InlineScrap" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="txtID"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[M559]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbSubProdType"/>
<O>
<![CDATA[ESLC]]></O>
</Parameter>
<Parameter>
<Attributes name="txtWeek"/>
<O>
<![CDATA[3]]></O>
</Parameter>
<Parameter>
<Attributes name="dtDateTime"/>
<O>
<![CDATA[2025-03-03]]></O>
</Parameter>
<Parameter>
<Attributes name="txtMonth"/>
<O>
<![CDATA[2]]></O>
</Parameter>
<Parameter>
<Attributes name="txtDay"/>
<O>
<![CDATA[7]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库良率加权报表（徐敏杰-工艺整合大数据）
WITH TIME_TAB AS (
SELECT 'DAY' AS DATE_TYPE
       ,DATE_TIMEKEY AS DATE_VALUE
       ,ROW_NUMBER() OVER(ORDER BY DATE_TIMEKEY) AS RN
  FROM DWD_CALENDAR
 WHERE FACTORY = 'ARRAY'
   AND TIME_TYPE = 'DAY'
   AND DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   AND DATE_TIMEKEY > TO_CHAR(TO_DATE('${dtDateTime}','YYYY-MM-DD') - INTERVAL '${txtDay}DAY','YYYYMMDD')
--月周
UNION ALL
SELECT S.DATE_TYPE
      ,S.DATE_VALUE
      ,S.RN
  FROM(SELECT T.DATE_TYPE
             ,T.DATE_VALUE
             ,ROW_NUMBER() OVER(PARTITION BY T.DATE_TYPE ORDER BY T.DATE_VALUE DESC) AS RN
         FROM(-- 周(此处获取当前周之前的所有周)
              SELECT DISTINCT 'WEEK' AS DATE_TYPE
                    ,N.WEEK_TIMEKEY AS DATE_VALUE
                FROM DWD_CALENDAR N
               INNER JOIN(-- 当前日期所在周
                          SELECT WEEK_TIMEKEY
                            FROM DWD_CALENDAR
                           WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                             AND FACTORY = 'ARRAY'
                             AND TIME_TYPE = 'DAY'
                         ) M
                       ON M.WEEK_TIMEKEY >= N.WEEK_TIMEKEY -- 当前周往前推
               WHERE N.FACTORY = 'ARRAY'
                 AND N.TIME_TYPE = 'DAY'
               UNION ALL
               -- 月(此处获取当前月之前的所有月)
               SELECT DISTINCT 'MONTH' AS DATE_TYPE
                     ,N.MONTH_TIMEKEY AS DATE_VALUE
                 FROM DWD_CALENDAR N
                INNER JOIN(SELECT MONTH_TIMEKEY
                             FROM DWD_CALENDAR
                            WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                              AND FACTORY = 'ARRAY'
                              AND TIME_TYPE = 'DAY'
                           ) M
                        ON M.MONTH_TIMEKEY >= N.MONTH_TIMEKEY -- 当前月往前推
                WHERE N.FACTORY = 'ARRAY'
                  AND N.TIME_TYPE = 'DAY'
              ) T
      ) S
 WHERE RN <= (CASE DATE_TYPE WHEN 'MONTH' THEN CAST('${txtMonth}' AS INT) ELSE CAST('${txtWeek}' AS INT) END)),
INLINE_S AS (
select T.DATE_TYPE
      ,T.DATE_VALUE
      ,T.PROD_CODE 
      ,T.INLINE_SCRAP_QTY
      ,T.A_INLINE_S_QTY
      ,T.T_INLINE_S_QTY
      ,T.O_INLINE_S_QTY
--      ,sum(T.INLINE_SCRAP_QTY) over (partition by T.DATE_TYPE,T.PROD_CODE) as INLINE_SCRAP_QTY_Total
--      ,sum(T.A_INLINE_S_QTY) over (partition by T.DATE_TYPE,T.PROD_CODE) as A_INLINE_S_QTY_Total
--      ,sum(T.T_INLINE_S_QTY) over (partition by T.DATE_TYPE,T.PROD_CODE) as T_INLINE_S_QTY_Total
--      ,sum(T.O_INLINE_S_QTY) over (partition by T.DATE_TYPE,T.PROD_CODE) as O_INLINE_S_QTY_Total
--      ,sum(T.INLINE_SCRAP_QTY) over (partition by T.DATE_VALUE) as INLINE_SCRAP_QTY_MONTH
--      ,sum(T.A_INLINE_S_QTY) over (partition by T.DATE_VALUE) as A_INLINE_S_QTY_MONTH
--      ,sum(T.T_INLINE_S_QTY) over (partition by T.DATE_VALUE) as T_INLINE_S_QTY_MONTH
--      ,sum(T.O_INLINE_S_QTY) over (partition by T.DATE_VALUE) as O_INLINE_S_QTY_MONTH
from (SELECT 'MONTH' AS DATE_TYPE
      ,S.MONTH_TIMEKEY AS DATE_VALUE
      ,S.PROD_CODE 
      ,SUM(S.SCRAP_PNL_QTY) AS INLINE_SCRAP_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('ARRAY') THEN S.SCRAP_PNL_QTY ELSE 0 END) A_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('TP') THEN S.SCRAP_PNL_QTY ELSE 0 END) T_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('OLED前段','OLED后段','OLED') THEN S.SCRAP_PNL_QTY ELSE 0 END) O_INLINE_S_QTY
  FROM DWS_INLINE_SCRAP_D S
 WHERE S.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
    AND S.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND S.PROD_CODE IN ('"+cmcbProdCode+"')")}
--   ${IF(LEN(cmcbProdSpec)=0,"","AND S.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND S.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
   ${IF(LEN(txtID) = 0,"", "AND S.SHEET_ID IN ('" + txtID + "')" )}  
   /*AND S.PROD_CODE = 'D17'
   AND S.SUB_PROD_TYPE = 'ESLC'*/
 GROUP BY S.MONTH_TIMEKEY
         ,S.PROD_CODE 
UNION ALL 
SELECT 'WEEK' AS DATE_TYPE
      ,S.WEEK_TIMEKEY AS DATE_VALUE
      ,S.PROD_CODE 
      ,SUM(S.SCRAP_PNL_QTY) AS INLINE_SCRAP_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('ARRAY') THEN S.SCRAP_PNL_QTY ELSE 0 END) A_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('TP') THEN S.SCRAP_PNL_QTY ELSE 0 END) T_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('OLED前段','OLED后段','OLED') THEN S.SCRAP_PNL_QTY ELSE 0 END) O_INLINE_S_QTY
  FROM DWS_INLINE_SCRAP_D S
  WHERE S.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtWeek} WEEK' ,'YYYYMMDD')
    AND S.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND S.PROD_CODE IN ('"+cmcbProdCode+"')")}
--   ${IF(LEN(cmcbProdSpec)=0,"","AND S.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND S.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
   ${IF(LEN(txtID) = 0,"", "AND S.SHEET_ID IN ('" + txtID + "')" )}  
   /*AND S.PROD_CODE = 'D17'
   AND S.SUB_PROD_TYPE = 'ESLC'*/
 GROUP BY S.WEEK_TIMEKEY 
         ,S.PROD_CODE 
UNION ALL 
SELECT 'DAY' AS DATE_TYPE
      ,S.DATE_TIMEKEY AS DATE_VALUE
      ,S.PROD_CODE 
      ,SUM(S.SCRAP_PNL_QTY) AS INLINE_SCRAP_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('ARRAY') THEN S.SCRAP_PNL_QTY ELSE 0 END) A_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('TP') THEN S.SCRAP_PNL_QTY ELSE 0 END) T_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('OLED前段','OLED后段','OLED') THEN S.SCRAP_PNL_QTY ELSE 0 END) O_INLINE_S_QTY
  FROM DWS_INLINE_SCRAP_D S
  WHERE S.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtDay} DAY' ,'YYYYMMDD')
    AND S.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND S.PROD_CODE IN ('"+cmcbProdCode+"')")}
--   ${IF(LEN(cmcbProdSpec)=0,"","AND S.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND S.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
   ${IF(LEN(txtID) = 0,"", "AND S.SHEET_ID IN ('" + txtID + "')" )}  
   /*AND S.PROD_CODE = 'D17'
   AND S.SUB_PROD_TYPE = 'ESLC'*/
 GROUP BY S.DATE_TIMEKEY 
         ,S.PROD_CODE ) T) 
         
SELECT   G.DATE_TYPE
        ,G.DATE_VALUE
        ,T.PROD_CODE 
        ,T.INLINE_SCRAP_QTY
        ,T.A_INLINE_S_QTY
        ,T.T_INLINE_S_QTY
        ,T.O_INLINE_S_QTY
      ,sum(T.INLINE_SCRAP_QTY) over (partition by T.DATE_TYPE,T.PROD_CODE) as INLINE_SCRAP_QTY_Total
      ,sum(T.A_INLINE_S_QTY) over (partition by T.DATE_TYPE,T.PROD_CODE) as A_INLINE_S_QTY_Total
      ,sum(T.T_INLINE_S_QTY) over (partition by T.DATE_TYPE,T.PROD_CODE) as T_INLINE_S_QTY_Total
      ,sum(T.O_INLINE_S_QTY) over (partition by T.DATE_TYPE,T.PROD_CODE) as O_INLINE_S_QTY_Total
      ,sum(T.INLINE_SCRAP_QTY) over (partition by T.DATE_VALUE) as INLINE_SCRAP_QTY_MONTH
      ,sum(T.A_INLINE_S_QTY) over (partition by T.DATE_VALUE) as A_INLINE_S_QTY_MONTH
      ,sum(T.T_INLINE_S_QTY) over (partition by T.DATE_VALUE) as T_INLINE_S_QTY_MONTH
      ,sum(T.O_INLINE_S_QTY) over (partition by T.DATE_VALUE) as O_INLINE_S_QTY_MONTH
FROM TIME_TAB G
LEFT JOIN INLINE_S T
ON T.DATE_VALUE=G.DATE_VALUE]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="SEARCH_GROUP" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="txtID"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[C466\',\'N236\',\'T219]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbDefectGroup"/>
<O>
<![CDATA[Array_Mura]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdSpec"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbSubProdType"/>
<O>
<![CDATA[ESLC\',\'LCFG\',\'P\',\'SLCFG\',\'SYZLC]]></O>
</Parameter>
<Parameter>
<Attributes name="txtWeek"/>
<O>
<![CDATA[0]]></O>
</Parameter>
<Parameter>
<Attributes name="dtDateTime"/>
<O>
<![CDATA[2025-03-08]]></O>
</Parameter>
<Parameter>
<Attributes name="txtMonth"/>
<O>
<![CDATA[1]]></O>
</Parameter>
<Parameter>
<Attributes name="txtDay"/>
<O>
<![CDATA[0]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
WITH TIME_TAB AS (
SELECT 'DAY' AS DATE_TYPE
       ,DATE_TIMEKEY AS DATE_VALUE
       ,ROW_NUMBER() OVER(ORDER BY DATE_TIMEKEY) AS RN
  FROM DWD_CALENDAR
 WHERE FACTORY = 'ARRAY'
   AND TIME_TYPE = 'DAY'
   AND DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   AND DATE_TIMEKEY > TO_CHAR(TO_DATE('${dtDateTime}','YYYY-MM-DD') - INTERVAL '${txtDay}DAY','YYYYMMDD')
--月周
UNION ALL
SELECT S.DATE_TYPE
      ,S.DATE_VALUE
      ,S.RN
  FROM(SELECT T.DATE_TYPE
             ,T.DATE_VALUE
             ,ROW_NUMBER() OVER(PARTITION BY T.DATE_TYPE ORDER BY T.DATE_VALUE DESC) AS RN
         FROM(-- 周(此处获取当前周之前的所有周)
              SELECT DISTINCT 'WEEK' AS DATE_TYPE
                    ,N.WEEK_TIMEKEY AS DATE_VALUE
                FROM DWD_CALENDAR N
               INNER JOIN(-- 当前日期所在周
                          SELECT WEEK_TIMEKEY
                            FROM DWD_CALENDAR
                           WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                             AND FACTORY = 'ARRAY'
                             AND TIME_TYPE = 'DAY'
                         ) M
                       ON M.WEEK_TIMEKEY >= N.WEEK_TIMEKEY -- 当前周往前推
               WHERE N.FACTORY = 'ARRAY'
                 AND N.TIME_TYPE = 'DAY'
               UNION ALL
               -- 月(此处获取当前月之前的所有月)
               SELECT DISTINCT 'MONTH' AS DATE_TYPE
                     ,N.MONTH_TIMEKEY AS DATE_VALUE
                 FROM DWD_CALENDAR N
                INNER JOIN(SELECT MONTH_TIMEKEY
                             FROM DWD_CALENDAR
                            WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                              AND FACTORY = 'ARRAY'
                              AND TIME_TYPE = 'DAY'
                           ) M
                        ON M.MONTH_TIMEKEY >= N.MONTH_TIMEKEY -- 当前月往前推
                WHERE N.FACTORY = 'ARRAY'
                  AND N.TIME_TYPE = 'DAY'
              ) T
      ) S
 WHERE RN <= (CASE DATE_TYPE WHEN 'MONTH' THEN CAST('${txtMonth}' AS INT) ELSE CAST('${txtWeek}' AS INT) END))
,PRODUCTTYPE AS(
SELECT DISTINCT PROD_TYPE,PROD_CODE
FROM IMP_CT_YLD_TARGET_MONTH_HY
WHERE 1=1 
AND PROD_TYPE IS NOT NULL
)
,GROUP_INFO AS(
SELECT T.DATE_TYPE
      ,T.DATE_VALUE
      ,P.PRODUCTCODE
      ,G.DEFECT_GROUP
      ,SUM(A.DFT_QTY) AS GROUP_DFT_TY
  FROM TIME_TAB T
       LEFT JOIN (SELECT distinct I.DEFECT_GROUP FROM IMP_CT_DFT_GROUP I) G
              ON 1=1
       LEFT JOIN (SELECT PRODUCTCODE FROM DWR_MES_PRODUCTSPEC WHERE 1=1 ${IF(LEN(cmcbProdCode)=0,"","AND PRODUCTCODE IN ('"+cmcbProdCode+"')")} GROUP BY PRODUCTCODE) P
              ON 1=1
       LEFT JOIN 
       (SELECT 'MONTH' AS DATE_TYPE
		      ,W.MONTH_TIMEKEY AS DATE_VALUE
		      ,W.PROD_CODE
		      ,G.DEFECT_GROUP 
		      ,W.PANEL_ID
		      ,1 AS DFT_QTY
		  FROM DWS_DFT_WAREHOUSING_D W
		       LEFT JOIN IMP_CT_DFT_GROUP G
		              ON W.DEFECT_CODE = G.DEFECT_CODE
		 WHERE W.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
		   AND W.DATE_TIMEKEY <= '${dtDateTime}'
           ${IF(LEN(cmcbProdCode)=0,"","AND W.PROD_CODE IN ('"+cmcbProdCode+"')")}
		   ${IF(LEN(cmcbProdSpec)=0,"","AND W.PROD_ID IN ('"+cmcbProdSpec+"')")}
		   ${IF(LEN(cmcbSubProdType)=0,"","AND W.SUB_PROD_TYPE IN ('"+cmcbSubProdType+"')")}
		   ${IF(LEN(txtID) = 0,"", "AND SUBSTR(S.PANEL_ID,1,11) IN ('" + txtID + "')" )} 
		 GROUP BY  W.MONTH_TIMEKEY
			      ,W.PROD_CODE
			      ,G.DEFECT_GROUP 
			      ,W.PANEL_ID
	    UNION ALL 
	    SELECT 'WEEK' AS DATE_TYPE
		      ,W.WEEK_TIMEKEY AS DATE_VALUE
		      ,W.PROD_CODE
		      ,G.DEFECT_GROUP 
		      ,W.PANEL_ID
		      ,1 AS DFT_QTY
		  FROM DWS_DFT_WAREHOUSING_D W
		       LEFT JOIN IMP_CT_DFT_GROUP G
		              ON W.DEFECT_CODE = G.DEFECT_CODE		
		 WHERE W.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtWeek} WEEK' ,'YYYYMMDD')
		   AND W.DATE_TIMEKEY <= '${dtDateTime}'
             ${IF(LEN(cmcbProdCode)=0,"","AND W.PROD_CODE IN ('"+cmcbProdCode+"')")}
		   ${IF(LEN(cmcbProdSpec)=0,"","AND W.PROD_ID IN ('"+cmcbProdSpec+"')")}
		   ${IF(LEN(cmcbSubProdType)=0,"","AND W.SUB_PROD_TYPE IN ('"+cmcbSubProdType+"')")}
		   ${IF(LEN(txtID) = 0,"", "AND SUBSTR(S.PANEL_ID,1,11) IN ('" + txtID + "')" )} 
		 GROUP BY  W.WEEK_TIMEKEY 
			      ,W.PROD_CODE
			      ,G.DEFECT_GROUP 
			      ,W.PANEL_ID
        UNION ALL 
        SELECT 'DAY' AS DATE_TYPE
		      ,W.DATE_TIMEKEY AS DATE_VALUE
		      ,W.PROD_CODE
		      ,G.DEFECT_GROUP 
		      ,W.PANEL_ID
		      ,1 AS DFT_QTY
		  FROM DWS_DFT_WAREHOUSING_D W
		       LEFT JOIN IMP_CT_DFT_GROUP G
		              ON W.DEFECT_CODE = G.DEFECT_CODE   
		 WHERE W.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtDay} DAY' ,'YYYYMMDD')
		   AND W.DATE_TIMEKEY <= '${dtDateTime}'
             ${IF(LEN(cmcbProdCode)=0,"","AND W.PROD_CODE IN ('"+cmcbProdCode+"')")}
		   ${IF(LEN(cmcbProdSpec)=0,"","AND W.PROD_ID IN ('"+cmcbProdSpec+"')")}
		   ${IF(LEN(cmcbSubProdType)=0,"","AND W.SUB_PROD_TYPE IN ('"+cmcbSubProdType+"')")}
		   ${IF(LEN(txtID) = 0,"", "AND SUBSTR(S.PANEL_ID,1,11) IN ('" + txtID + "')" )} 
		 GROUP BY  W.DATE_TIMEKEY 
			      ,W.PROD_CODE
			      ,G.DEFECT_GROUP 
			      ,W.PANEL_ID
	    ) A
	   ON T.DATE_VALUE = A.DATE_VALUE
	  AND G.DEFECT_GROUP = A.DEFECT_GROUP
	  AND P.PRODUCTCODE = A.PROD_CODE
 where 1=1
 ${IF(LEN(cmcbDefectGroup)=0,"","AND G.DEFECT_GROUP  IN ('"+cmcbDefectGroup+"')")}
 GROUP BY T.DATE_TYPE
         ,T.DATE_VALUE
	     ,P.PRODUCTCODE
	     ,G.DEFECT_GROUP
 ORDER BY CASE WHEN T.DATE_TYPE = 'MONTH' THEN 1
              WHEN T.DATE_TYPE = 'WEEK' THEN 2
              ELSE 3
          END,
         T.DATE_VALUE
         ,P.PRODUCTCODE
 ) 
 
 select  GI.DATE_TYPE
        ,GI.DATE_VALUE
        ,GI.PRODUCTCODE
        ,P1.Prod_Type
        ,GI.DEFECT_GROUP
        ,GI.GROUP_DFT_TY
        ,SUM(GI.GROUP_DFT_TY) OVER(PARTITION BY GI.DATE_VALUE,COALESCE(GI.DEFECT_GROUP,'/')) AS ALL_DFT_QTY
        ,SUM(GI.GROUP_DFT_TY) OVER(PARTITION BY P1.Prod_Type,GI.DATE_VALUE,COALESCE(GI.DEFECT_GROUP,'/')) AS ALL_TYPE_DFT_QTY
        ,SUM(GI.GROUP_DFT_TY) OVER(PARTITION BY GI.DATE_TYPE,COALESCE(GI.DEFECT_GROUP,'/')) AS GROUP_QTY_Total
        ,SUM(GI.GROUP_DFT_TY) OVER(PARTITION BY GI.PRODUCTCODE,GI.DATE_TYPE,COALESCE(GI.DEFECT_GROUP,'/')) AS GROUP_QTY_Total_PRODUCT
        ,SUM(GI.GROUP_DFT_TY) OVER(PARTITION BY P1.Prod_Type,GI.DATE_TYPE,COALESCE(GI.DEFECT_GROUP,'/')) AS GROUP_QTY_Total_PRODUCTTYPE        
from GROUP_INFO GI
LEFT JOIN PRODUCTTYPE P1
       ON GI.PRODUCTCODE=P1.PROD_CODE
 ORDER BY CASE WHEN GI.DATE_TYPE = 'MONTH' THEN 1
              WHEN GI.DATE_TYPE = 'WEEK' THEN 2
              ELSE 3
          end
         ,GI.DATE_VALUE
         ,GI.PRODUCTCODE
         ,GI.DEFECT_GROUP]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="SEARCH_DEFECTCODE" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="txtID"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[C466\',\'N236\',\'T219]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbDefectGroup"/>
<O>
<![CDATA[Array_Mura]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdSpec"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbDefectCode"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbSubProdType"/>
<O>
<![CDATA[ESLC\',\'LCFG\',\'P\',\'SLCFG\',\'SYZLC]]></O>
</Parameter>
<Parameter>
<Attributes name="txtWeek"/>
<O>
<![CDATA[0]]></O>
</Parameter>
<Parameter>
<Attributes name="dtDateTime"/>
<O>
<![CDATA[2025-03-08]]></O>
</Parameter>
<Parameter>
<Attributes name="txtMonth"/>
<O>
<![CDATA[1]]></O>
</Parameter>
<Parameter>
<Attributes name="txtDay"/>
<O>
<![CDATA[0]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
WITH TIME_TAB AS (
SELECT 'DAY' AS DATE_TYPE
       ,DATE_TIMEKEY AS DATE_VALUE
       ,ROW_NUMBER() OVER(ORDER BY DATE_TIMEKEY) AS RN
  FROM DWD_CALENDAR
 WHERE FACTORY = 'ARRAY'
   AND TIME_TYPE = 'DAY'
   AND DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   AND DATE_TIMEKEY > TO_CHAR(TO_DATE('${dtDateTime}','YYYY-MM-DD') - INTERVAL '${txtDay}DAY','YYYYMMDD')
--月周
UNION ALL
SELECT S.DATE_TYPE
      ,S.DATE_VALUE
      ,S.RN
  FROM(SELECT T.DATE_TYPE
             ,T.DATE_VALUE
             ,ROW_NUMBER() OVER(PARTITION BY T.DATE_TYPE ORDER BY T.DATE_VALUE DESC) AS RN
         FROM(-- 周(此处获取当前周之前的所有周)
              SELECT DISTINCT 'WEEK' AS DATE_TYPE
                    ,N.WEEK_TIMEKEY AS DATE_VALUE
                FROM DWD_CALENDAR N
               INNER JOIN(-- 当前日期所在周
                          SELECT WEEK_TIMEKEY
                            FROM DWD_CALENDAR
                           WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                             AND FACTORY = 'ARRAY'
                             AND TIME_TYPE = 'DAY'
                         ) M
                       ON M.WEEK_TIMEKEY >= N.WEEK_TIMEKEY -- 当前周往前推
               WHERE N.FACTORY = 'ARRAY'
                 AND N.TIME_TYPE = 'DAY'
               UNION ALL
               -- 月(此处获取当前月之前的所有月)
               SELECT DISTINCT 'MONTH' AS DATE_TYPE
                     ,N.MONTH_TIMEKEY AS DATE_VALUE
                 FROM DWD_CALENDAR N
                INNER JOIN(SELECT MONTH_TIMEKEY
                             FROM DWD_CALENDAR
                            WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                              AND FACTORY = 'ARRAY'
                              AND TIME_TYPE = 'DAY'
                           ) M
                        ON M.MONTH_TIMEKEY >= N.MONTH_TIMEKEY -- 当前月往前推
                WHERE N.FACTORY = 'ARRAY'
                  AND N.TIME_TYPE = 'DAY'
              ) T
      ) S
 WHERE RN <= (CASE DATE_TYPE WHEN 'MONTH' THEN CAST('${txtMonth}' AS INT) ELSE CAST('${txtWeek}' AS INT) END)),
PRODUCTTYPE AS(
SELECT DISTINCT PROD_TYPE,PROD_CODE
FROM IMP_CT_YLD_TARGET_MONTH_HY
WHERE 1=1 
AND PROD_TYPE IS NOT NULL
),
DFT_INFO AS(
SELECT 'MONTH' AS DATE_TYPE
      ,D.MONTH_TIMEKEY AS DATE_VALUE
      ,P.Prod_Type
      ,D.PROD_CODE 
      ,COALESCE(G.FACTORY,'/') AS FACTORY
      ,COALESCE(G.DEFECT_GROUP,'/') AS DEFECT_GROUP 
      ,D.DEFECT_CODE
      ,COALESCE(G.DEFECT_DESC,D.DEFECT_CODE) AS DEFECT_DESC  
      ,SUM(D.DFT_QTY) AS DFT_QTY
  FROM DWS_DFT_WAREHOUSING_D D
       LEFT JOIN PRODUCTTYPE P
              ON D.PROD_CODE=P.PROD_CODE
       LEFT JOIN IMP_CT_DFT_GROUP G
              ON D.DEFECT_CODE = G.DEFECT_CODE 
WHERE D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
  AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND D.PROD_CODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND D.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
   ${IF(LEN(txtID) = 0,"", "AND D.SHEET_ID IN ('" + txtID + "')" )} 
 GROUP BY D.MONTH_TIMEKEY
         ,D.PROD_CODE
         ,P.Prod_Type
         ,COALESCE(G.FACTORY,'/') 
         ,COALESCE(G.DEFECT_GROUP,'/')
         ,D.DEFECT_CODE
         ,COALESCE(G.DEFECT_DESC,D.DEFECT_CODE)
UNION ALL 
SELECT 'WEEK' AS DATE_TYPE
      ,D.WEEK_TIMEKEY AS DATE_VALUE
      ,P.Prod_Type
      ,D.PROD_CODE 
      ,COALESCE(G.FACTORY,'/') AS FACTORY
      ,COALESCE(G.DEFECT_GROUP,'/') AS DEFECT_GROUP 
      ,D.DEFECT_CODE
      ,COALESCE(G.DEFECT_DESC,D.DEFECT_CODE) AS DEFECT_DESC  
      ,SUM(D.DFT_QTY) AS DFT_QTY 
  FROM DWS_DFT_WAREHOUSING_D D
       LEFT JOIN PRODUCTTYPE P
              ON D.PROD_CODE=P.PROD_CODE
       LEFT JOIN IMP_CT_DFT_GROUP G
              ON D.DEFECT_CODE = G.DEFECT_CODE 
WHERE D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtWeek} WEEK' ,'YYYYMMDD')
  AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND D.PROD_CODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND D.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
   ${IF(LEN(txtID) = 0,"", "AND D.SHEET_ID IN ('" + txtID + "')" )} 
 GROUP BY D.WEEK_TIMEKEY 
         ,D.PROD_CODE
         ,P.Prod_Type 
         ,COALESCE(G.FACTORY,'/') 
         ,COALESCE(G.DEFECT_GROUP,'/')
         ,D.DEFECT_CODE
         ,COALESCE(G.DEFECT_DESC,D.DEFECT_CODE)
UNION ALL 
SELECT 'DAY' AS DATE_TYPE
      ,D.DATE_TIMEKEY AS DATE_VALUE
      ,P.Prod_Type
      ,D.PROD_CODE
      ,COALESCE(G.FACTORY,'/') AS FACTORY
      ,COALESCE(G.DEFECT_GROUP,'/') AS DEFECT_GROUP 
      ,D.DEFECT_CODE
      ,COALESCE(G.DEFECT_DESC,D.DEFECT_CODE) AS DEFECT_DESC  
      ,SUM(D.DFT_QTY) AS DFT_QTY 
  FROM DWS_DFT_WAREHOUSING_D D
  LEFT JOIN PRODUCTTYPE P
              ON D.PROD_CODE=P.PROD_CODE
       LEFT JOIN IMP_CT_DFT_GROUP G
              ON D.DEFECT_CODE = G.DEFECT_CODE 
WHERE D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtDay} DAY' ,'YYYYMMDD')
  AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND D.PROD_CODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND D.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
   ${IF(LEN(txtID) = 0,"", "AND D.SHEET_ID IN ('" + txtID + "')" )} 
 GROUP BY D.DATE_TIMEKEY 
         ,D.PROD_CODE
         ,P.Prod_Type 
         ,COALESCE(G.FACTORY,'/') 
         ,COALESCE(G.DEFECT_GROUP,'/')
         ,D.DEFECT_CODE
         ,COALESCE(G.DEFECT_DESC,D.DEFECT_CODE)
)

select T.DATE_TYPE
      ,T.DATE_VALUE
      ,DI.PROD_CODE
      ,DI.Prod_Type
      ,DI.FACTORY
      ,DI.DEFECT_GROUP 
      ,DI.DEFECT_CODE
      ,DI.DEFECT_DESC  
      ,DI.DFT_QTY
      ,SUM(DI.DFT_QTY) OVER(PARTITION BY T.DATE_VALUE,DI.Prod_Type,COALESCE(DI.DEFECT_DESC ,'/')) AS ALL_TYPE_DFT_QTY
     ,SUM(DI.DFT_QTY) OVER(PARTITION BY T.DATE_VALUE,COALESCE(DI.DEFECT_DESC ,'/')) AS ALL_DFT_QTY
      ,SUM(DI.DFT_QTY) OVER(PARTITION BY T.DATE_TYPE,COALESCE(DI.DEFECT_DESC ,'/')) AS DFT_QTY_Total
     ,SUM(DI.DFT_QTY) OVER(PARTITION BY DI.PROD_CODE,T.DATE_TYPE,COALESCE(DI.DEFECT_DESC ,'/')) AS DFT_QTY_Total_PRODUCT
      ,SUM(DI.DFT_QTY) OVER(PARTITION BY DI.Prod_Type,T.DATE_TYPE,COALESCE(DI.DEFECT_DESC ,'/')) AS DFT_QTY_Total_PRODUCTTYPE
from TIME_TAB T
left join DFT_INFO DI
on T.DATE_VALUE=DI.DATE_VALUE 
   ${IF(LEN(cmcbDefectGroup)=0,"","AND DI.DEFECT_GROUP  IN ('"+cmcbDefectGroup+"')")}
   ${IF(LEN(cmcbDefectCode)=0,"","AND DI.DEFECT_DESC  IN ('"+cmcbDefectCode+"')")}
   
ORDER BY CASE WHEN T.DATE_TYPE = 'MONTH' THEN 1
              WHEN T.DATE_TYPE = 'WEEK' THEN 2
              ELSE 3
          end
         ,T.DATE_VALUE
         ,DI.PROD_CODE]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="DEFECT_CODE" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="cmcbDefectGroup"/>
<O>
<![CDATA[]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
SELECT DEFECT_GROUP
      ,DEFECT_CODE 
      ,DEFECT_DESC 
  FROM IMP_CT_DFT_GROUP
 WHERE 1=1
   ${IF(LEN(cmcbDefectGroup)=0,"","AND DEFECT_GROUP IN ('"+cmcbDefectGroup+"')")}
 GROUP BY DEFECT_GROUP
	      ,DEFECT_CODE 
	      ,DEFECT_DESC
 ORDER BY DEFECT_GROUP,DEFECT_CODE]]></Query>
