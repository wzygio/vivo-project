<Query>
<![CDATA[SELECT 
    DESCRIPTION AS ENUM_VALUE
FROM
    DWR_MES_ENUMDEFVALUE_V
WHERE
    ENUM_ID LIKE '%MESSubProductionType'
GROUP BY
    DESCRIPTION
ORDER BY
    DESCRIPTION]]></Query>
