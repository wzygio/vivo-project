<TableData name="SEARCH_TARGET" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[C20]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
SELECT PROD_CODE 
      ,'Target' AS VALUE_TYPE
      ,REPLACE(month_timekey,'-','M') AS MONTH_TIMEKEY 
      ,PTZH_YLD_TARGET AS TARGET_VALUE
      ,ruku_yld_target AS YIELD_YUCE
      ,sale_predict
  FROM IMP_CT_YLD_TARGET_MONTH_HY
 WHERE 1=1
 and month_timekey>='2024-01'
 ${IF(LEN(cmcbProdCode)= 0, "", "AND PROD_CODE IN ('" + cmcbProdCode + "')")}
 order by MONTH_TIMEKEY]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="SEARCH_RUKU" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="txtID"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[M559]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdSpec"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbSubProdType"/>
<O>
<![CDATA[ESLC\',\'P\',\'LCFG\',\'SLCFG\',\'SYZLC]]></O>
</Parameter>
<Parameter>
<Attributes name="txtWeek"/>
<O>
<![CDATA[3]]></O>
</Parameter>
<Parameter>
<Attributes name="dtDateTime"/>
<O>
<![CDATA[2025-03-03]]></O>
</Parameter>
<Parameter>
<Attributes name="txtMonth"/>
<O>
<![CDATA[2]]></O>
</Parameter>
<Parameter>
<Attributes name="txtDay"/>
<O>
<![CDATA[7]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
WITH TIME_TAB AS (
SELECT 'DAY' AS DATE_TYPE
       ,DATE_TIMEKEY AS DATE_VALUE
       ,ROW_NUMBER() OVER(ORDER BY DATE_TIMEKEY) AS RN
  FROM DWD_CALENDAR
 WHERE FACTORY = 'ARRAY'
   AND TIME_TYPE = 'DAY'
   AND DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   AND DATE_TIMEKEY > TO_CHAR(TO_DATE('${dtDateTime}','YYYY-MM-DD') - INTERVAL '${txtDay}DAY','YYYYMMDD')
--月周
UNION ALL
SELECT S.DATE_TYPE
      ,S.DATE_VALUE
      ,S.RN
  FROM(SELECT T.DATE_TYPE
             ,T.DATE_VALUE
             ,ROW_NUMBER() OVER(PARTITION BY T.DATE_TYPE ORDER BY T.DATE_VALUE DESC) AS RN
         FROM(-- 周(此处获取当前周之前的所有周)
              SELECT DISTINCT 'WEEK' AS DATE_TYPE
                    ,N.WEEK_TIMEKEY AS DATE_VALUE
                FROM DWD_CALENDAR N
               INNER JOIN(-- 当前日期所在周
                          SELECT WEEK_TIMEKEY
                            FROM DWD_CALENDAR
                           WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                             AND FACTORY = 'ARRAY'
                             AND TIME_TYPE = 'DAY'
                         ) M
                       ON M.WEEK_TIMEKEY >= N.WEEK_TIMEKEY -- 当前周往前推
               WHERE N.FACTORY = 'ARRAY'
                 AND N.TIME_TYPE = 'DAY'
               UNION ALL
               -- 月(此处获取当前月之前的所有月)
               SELECT DISTINCT 'MONTH' AS DATE_TYPE
                     ,N.MONTH_TIMEKEY AS DATE_VALUE
                 FROM DWD_CALENDAR N
                INNER JOIN(SELECT MONTH_TIMEKEY
                             FROM DWD_CALENDAR
                            WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                              AND FACTORY = 'ARRAY'
                              AND TIME_TYPE = 'DAY'
                           ) M
                        ON M.MONTH_TIMEKEY >= N.MONTH_TIMEKEY -- 当前月往前推
                WHERE N.FACTORY = 'ARRAY'
                  AND N.TIME_TYPE = 'DAY'
              ) T
      ) S
 WHERE RN <= (CASE DATE_TYPE WHEN 'MONTH' THEN CAST('${txtMonth}' AS INT) ELSE CAST('${txtWeek}' AS INT) END)),
DWS_YLD_WAREHOUSING_D_F AS(
SELECT  G.MONTH_TIMEKEY 
       ,G.WEEK_TIMEKEY 
       ,G.DATE_TIMEKEY 
       ,G.PROD_CODE 
       ,G.PROD_ID 
       ,G.SUB_PROD_TYPE 
       ,G.SUB_PROD_ID
       ,G.PANEL_GRADE 
       ,G.DTL_GRADE
       ,G.GRADE_FLAG
       ,CASE WHEN G.RISK_FACTORY='ARRAY+OLED'
             THEN G.OUTPUT_QTY/2
             ELSE G.OUTPUT_QTY
             END AS OUTPUT_QTY
       ,G.SHEET_ID 
       ,G.RISK_FLAG 
       ,G.A1_SHIP_FLAG
       ,CASE WHEN G.RISK_FACTORY='ARRAY+OLED'
             THEN UNNEST(STRING_TO_ARRAY(G.RISK_FACTORY,'+') ) 
             ELSE G.RISK_FACTORY 
             END AS RISK_FACTORY 
	   ,G.RISKCOMMENT --风险品描述
FROM (            
SELECT  T.MONTH_TIMEKEY 
       ,T.WEEK_TIMEKEY 
       ,T.DATE_TIMEKEY 
       ,T.PROD_CODE 
       ,T.PROD_ID 
       ,T.SUB_PROD_TYPE 
       ,T.SUB_PROD_ID
       ,T.PANEL_GRADE 
       ,DTL_GRADE
       ,T.OUTPUT_QTY
       ,T.SHEET_ID 
       ,T.RISK_FLAG 
       ,T.GRADE_FLAG
		      ,CASE WHEN (T.RISK_FACTORY IS NOT NULL AND T.RISK_FACTORY <>'')
		            THEN  T.RISK_FACTORY
		            WHEN (T.RISK_FACTORY IS  NULL OR T.RISK_FACTORY ='') AND (R.RISK_FACTORY IS NOT NULL OR R.RISK_FACTORY <>'')
		            THEN R.RISK_FACTORY 
		            ELSE T.RISKFACTORY 
		            END AS RISK_FACTORY--风险品责任工厂
       ,CASE WHEN (T.RISK_DSC IS NOT NULL OR T.RISK_DSC <>'')
		            THEN  T.RISK_DSC
		            WHEN (T.RISK_DSC IS NULL  OR T.RISK_DSC ='') AND (R.RISK_COMMENT IS NOT NULL OR R.RISK_COMMENT <>'')
		            THEN R.RISK_COMMENT 
		            ELSE T.RISKCOMMENT 
		            END AS RISKCOMMENT --风险品描述
       ,T.A1_SHIP_FLAG
FROM (
      SELECT Y.MONTH_TIMEKEY 
            ,Y.WEEK_TIMEKEY 
            ,D.FIRST_SHIP_DATE AS DATE_TIMEKEY 
            ,P.PRODUCTCODE AS PROD_CODE 
            ,D.PROD_ID 
            ,R.SUBPRODUCTIONTYPE  AS SUB_PROD_TYPE 
            ,D.SUB_PROD_ID
            ,D.PANEL_GRADE 
            ,D.PANEL_ID 
            ,CASE WHEN D.DTL_GRADE IS NULL 
                  THEN 'S'
	              ELSE D.DTL_GRADE
	              END AS DTL_GRADE 
	        ,G.GRADE_FLAG  
            ,SUM(D.OPER_OUT_PNL_QTY) AS OUTPUT_QTY
	        ,SUBSTR(D.PANEL_ID,1,11) AS SHEET_ID
	        ,SUBSTR(D.PANEL_ID,1,12) AS GLASS_ID
            ,D.RISK_FLAG  
            ,H.RISK_FACTORY 
            ,R.RISKFACTORY 
            ,R.RISKCOMMENT 
            ,H.RISK_DSC
            ,CASE WHEN D.FIRST_SHIP_DATE >= '20221127' AND D.DTL_GRADE = 'A1' 
                  THEN 'Y' 
                  ELSE D.A1_SHIP_FLAG  
                  END AS A1_SHIP_FLAG --11月27日后A1全部算为良品，不再卡控是否出货，11月27日前保持A1出货为良品
       FROM DWT_WAREHOUSING_PNL D
  LEFT JOIN IMP_YLD_GRADE_FLAG G 
         ON D.DTL_GRADE=G.GRADE 
  LEFT JOIN DWD_CALENDAR Y
	     ON D.FIRST_SHIP_DATE = Y.TIME_KEY
	    AND Y.FACTORY = 'ARRAY'
  LEFT JOIN DWR_MES_PRODUCTSPEC P
	     ON D.PROD_ID = P.PRODUCTSPECNAME
  LEFT JOIN DWR_MES_PRODUCTREQUEST R
	     ON D.SUB_PROD_ID = R.PRODUCTREQUESTNAME  
	     LEFT JOIN (SELECT COALESCE(P1.PANEL_ID, P.PANEL_ID, A.LOTNAME) AS LOTNAME,
                    A.RISKFACTORY AS RISK_FACTORY ,
                   (A.RISKCODE::TEXT || ' '::TEXT) || COALESCE(T.DESCRIPTION, ''::CHARACTER VARYING)::TEXT AS RISK_DSC
                  FROM DWR_MES_CT_RISKHOLDPRODUCT A
             LEFT JOIN DWR_MES_PRODUCTSPEC_V B 
                    ON B.FACTORY::TEXT = 'POSTCELL'::TEXT 
                   AND SUBSTR(A.LOTNAME::TEXT, 3, 2) = B.OLD_PRODUCT_CODE::TEXT
             LEFT JOIN DWR_MES_PNL P 
                    ON A.LOTNAME::TEXT =LEFT(P.PANEL_ID::TEXT, 12) 
                   AND LENGTH(A.LOTNAME::TEXT) = 12
             LEFT JOIN DWR_MES_PNL P1 
                    ON A.LOTNAME::TEXT = LEFT(P1.PANEL_ID::TEXT, 11) 
                   AND LENGTH(A.LOTNAME::TEXT) = 11
              LEFT JOIN ( SELECT DESCRIPTION,
                                 REASONCODE
                            FROM DWR_MES_REASONCODE
                           WHERE DWR_MES_REASONCODE.REASONCODETYPE::TEXT = 'RiskHoldCode'::TEXT 
                           AND (DWR_MES_REASONCODE.AVAILABILITY::TEXT = ANY (ARRAY['Available'::TEXT, 'Availability'::TEXT]A)) 
                           AND DWR_MES_REASONCODE.SUPERREASONCODE IS NOT NULL) T
                   ON T.REASONCODE::TEXT = A.RISKCODE::TEXT
              GROUP BY COALESCE(P1.PANEL_ID, P.PANEL_ID, A.LOTNAME)
                       , A.RISKFACTORY
                        ,(A.RISKCODE::TEXT || ' '::TEXT) || COALESCE(T.DESCRIPTION, ''::CHARACTER VARYING)::TEXT
                        ,A.RISKDUTYUSER 
                        ,A.RISKDEPT ) H 
        ON D.PANEL_ID =H.LOTNAME
     WHERE D.FIRST_SHIP_DATE >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
       AND D.FIRST_SHIP_DATE <= REPLACE('${dtDateTime}','-','')
       AND D.DATE_TIMEKEY>=TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
--       AND P.PRODUCTCODE ='C20'
--       AND D.FIRST_SHIP_DATE ='20231221'
--       AND R.SUBPRODUCTIONTYPE IN ('ESLC','P','LCFG','SLCFG','SYZLC')
       AND D.RISK_FLAG ='Y'
       AND D.LAST_FLAG='Y'
   ${IF(LEN(cmcbProdCode)=0,"","AND P.PRODUCTCODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND R.SUBPRODUCTIONTYPE IN ('" + cmcbSubProdType + "')" )}
--   ${IF(LEN(txtID) = 0,"", "AND D.SHEET_ID IN ('" + txtID + "')" )}  
GROUP BY     Y.MONTH_TIMEKEY 
            ,Y.WEEK_TIMEKEY 
            ,D.OPER_OUT_PNL_QTY
            ,D.FIRST_SHIP_DATE 
            ,P.PRODUCTCODE  
            ,D.PROD_ID 
            ,D.PANEL_ID 
            ,R.SUBPRODUCTIONTYPE  
            ,D.SUB_PROD_ID
            ,D.PANEL_GRADE 
            ,CASE WHEN D.DTL_GRADE IS NULL 
                  THEN 'S'
	              ELSE D.DTL_GRADE
	              END  
	        ,SUBSTR(D.PANEL_ID,1,11) 
	        ,SUBSTR(D.PANEL_ID,1,12) 
            ,D.RISK_FLAG  
            ,H.RISK_FACTORY
            ,R.RISKFACTORY 
	        ,G.GRADE_FLAG  
            ,CASE WHEN D.FIRST_SHIP_DATE >= '20221127' AND D.DTL_GRADE = 'A1' 
                  THEN 'Y' 
                  ELSE D.A1_SHIP_FLAG  
                  END
            ,R.RISKCOMMENT 
            ,H.RISK_DSC
          ) T  
 LEFT JOIN IMP_RUKU_RISK_DUTY R 
         ON T.PROD_CODE=R.PROD_CODE 
         AND T.SUB_PROD_ID=R.SUB_PROD_ID 
         ) G    
         )
,YLD_INFO AS(
SELECT 'MONTH' AS DATE_TYPE
      ,D.MONTH_TIMEKEY AS DATE_VALUE
      ,D.PROD_CODE 
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' THEN 0 ELSE CASE WHEN D.GRADE_FLAG ='Y' OR (D.DTL_GRADE = 'A1' AND D.A1_SHIP_FLAG = 'Y') THEN D.OUTPUT_QTY ELSE 0 END END ) AS AA1_QTY --良品数
      ,SUM(CASE WHEN D.RISK_FLAG <> 'Y' AND (D.GRADE_FLAG ='N' OR (D.DTL_GRADE = 'A1' AND D.A1_SHIP_FLAG = 'N')) THEN D.OUTPUT_QTY ELSE 0 END) AS NOT_RISK_DFT_QTY --非风险品不良数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' THEN D.OUTPUT_QTY ELSE 0 END) AS RISK_AA1_QTY --风险品AA1数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('ARRAY','阵列部') THEN OUTPUT_QTY  ELSE 0 END) AS A_RISK_AA1_QTY --风险品AA1的ARRAY责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('TP','触控部') THEN OUTPUT_QTY  ELSE 0 END) AS T_RISK_AA1_QTY --风险品AA1的TP责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('OLED','蒸镀封装部') THEN D.OUTPUT_QTY ELSE 0 END) AS O_RISK_AA1_QTY --风险品AA1的OLED责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('屏体部') THEN D.OUTPUT_QTY ELSE 0 END) AS C_RISK_AA1_QTY --风险品AA1的CELL责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND (D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')) THEN D.OUTPUT_QTY ELSE 0 END) AS Q_RISK_AA1_QTY --风险品AA1未分责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('ARRAY','阵列部') THEN D.OUTPUT_QTY ELSE 0 END) AS A_RISK_QTY --ARRAY责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('TP','触控部') THEN D.OUTPUT_QTY ELSE 0 END) AS T_RISK_QTY --TP责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('OLED','蒸镀封装部') THEN D.OUTPUT_QTY ELSE 0 END) AS O_RISK_QTY --OLED责风险品数
       ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('屏体部') THEN D.OUTPUT_QTY ELSE 0 END) AS C_RISK_QTY --CELL责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY='开发责' THEN D.OUTPUT_QTY ELSE 0 END) AS KFZ_RISK_AA1_QTY --开发责风险品AA1数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y'  THEN  D.OUTPUT_QTY ELSE 0 END) AS RISK_QTY --风险品总数
  FROM DWS_YLD_WAREHOUSING_D_F D  
 WHERE 1=1
 GROUP BY  D.MONTH_TIMEKEY
	     ,D.PROD_CODE  	  
UNION ALL 
SELECT 'WEEK' AS DATE_TYPE
      ,D.WEEK_TIMEKEY AS DATE_VALUE
      ,D.PROD_CODE 
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' THEN 0 ELSE CASE WHEN D.GRADE_FLAG ='Y' OR (D.DTL_GRADE = 'A1' AND D.A1_SHIP_FLAG = 'Y') THEN D.OUTPUT_QTY ELSE 0 END END ) AS AA1_QTY --良品数
      ,SUM(CASE WHEN D.RISK_FLAG <> 'Y' AND (D.GRADE_FLAG ='N' OR (D.DTL_GRADE = 'A1' AND D.A1_SHIP_FLAG = 'N')) THEN D.OUTPUT_QTY ELSE 0 END) AS NOT_RISK_DFT_QTY --非风险品不良数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' THEN D.OUTPUT_QTY ELSE 0 END) AS RISK_AA1_QTY --风险品AA1数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('ARRAY','阵列部') THEN OUTPUT_QTY  ELSE 0 END) AS A_RISK_AA1_QTY --风险品AA1的ARRAY责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('TP','触控部') THEN OUTPUT_QTY  ELSE 0 END) AS T_RISK_AA1_QTY --风险品AA1的TP责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('OLED','蒸镀封装部') THEN D.OUTPUT_QTY ELSE 0 END) AS O_RISK_AA1_QTY --风险品AA1的OLED责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('屏体部') THEN D.OUTPUT_QTY ELSE 0 END) AS C_RISK_AA1_QTY --风险品AA1的CELL责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND (D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')) THEN D.OUTPUT_QTY ELSE 0 END) AS Q_RISK_AA1_QTY --风险品AA1未分责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('ARRAY','阵列部') THEN D.OUTPUT_QTY ELSE 0 END) AS A_RISK_QTY --ARRAY责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('TP','触控部') THEN D.OUTPUT_QTY ELSE 0 END) AS T_RISK_QTY --TP责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('OLED','蒸镀封装部') THEN D.OUTPUT_QTY ELSE 0 END) AS O_RISK_QTY --OLED责风险品数
       ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('屏体部') THEN D.OUTPUT_QTY ELSE 0 END) AS C_RISK_QTY --CELL责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY='开发责' THEN D.OUTPUT_QTY ELSE 0 END) AS KFZ_RISK_AA1_QTY --开发责风险品AA1数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y'  THEN  D.OUTPUT_QTY ELSE 0 END) AS RISK_QTY --风险品总数
      FROM DWS_YLD_WAREHOUSING_D_F D  
 WHERE 1=1        
 GROUP BY  D.WEEK_TIMEKEY
	     ,D.PROD_CODE
UNION ALL 
SELECT 'DAY' AS DATE_TYPE
      ,D.DATE_TIMEKEY AS DATE_VALUE
      ,D.PROD_CODE 
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' THEN 0 ELSE CASE WHEN D.GRADE_FLAG ='Y' OR (D.DTL_GRADE = 'A1' AND D.A1_SHIP_FLAG = 'Y') THEN D.OUTPUT_QTY ELSE 0 END END ) AS AA1_QTY --良品数
      ,SUM(CASE WHEN D.RISK_FLAG <> 'Y' AND (D.GRADE_FLAG ='N' OR (D.DTL_GRADE = 'A1' AND D.A1_SHIP_FLAG = 'N')) THEN D.OUTPUT_QTY ELSE 0 END) AS NOT_RISK_DFT_QTY --非风险品不良数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' THEN D.OUTPUT_QTY ELSE 0 END) AS RISK_AA1_QTY --风险品AA1数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('ARRAY','阵列部') THEN OUTPUT_QTY  ELSE 0 END) AS A_RISK_AA1_QTY --风险品AA1的ARRAY责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('TP','触控部') THEN OUTPUT_QTY  ELSE 0 END) AS T_RISK_AA1_QTY --风险品AA1的TP责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('OLED','蒸镀封装部') THEN D.OUTPUT_QTY ELSE 0 END) AS O_RISK_AA1_QTY --风险品AA1的OLED责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('屏体部') THEN D.OUTPUT_QTY ELSE 0 END) AS C_RISK_AA1_QTY --风险品AA1的CELL责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND (D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')) THEN D.OUTPUT_QTY ELSE 0 END) AS Q_RISK_AA1_QTY --风险品AA1未分责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('ARRAY','阵列部') THEN D.OUTPUT_QTY ELSE 0 END) AS A_RISK_QTY --ARRAY责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('TP','触控部') THEN D.OUTPUT_QTY ELSE 0 END) AS T_RISK_QTY --TP责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('OLED','蒸镀封装部') THEN D.OUTPUT_QTY ELSE 0 END) AS O_RISK_QTY --OLED责风险品数
       ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('屏体部') THEN D.OUTPUT_QTY ELSE 0 END) AS C_RISK_QTY --CELL责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y' AND D.RISK_FACTORY='开发责' THEN D.OUTPUT_QTY ELSE 0 END) AS KFZ_RISK_AA1_QTY --开发责风险品AA1数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.GRADE_FLAG ='Y'  THEN  D.OUTPUT_QTY ELSE 0 END) AS RISK_QTY --风险品总数
      FROM DWS_YLD_WAREHOUSING_D_F D
 WHERE 1=1
--   AND PROD_CODE ='C16'
--   AND DATE_TIMEKEY ='20231115'
 GROUP BY  D.DATE_TIMEKEY 
	     ,D.PROD_CODE )
,DFT_INFO AS(
SELECT 'MONTH' AS DATE_TYPE
      ,D.MONTH_TIMEKEY AS DATE_VALUE
      ,D.PROD_CODE 
      , CASE WHEN D.RISK_FACTORY IN('ARRAY','阵列部')
             THEN 'ARRAY'
             WHEN D.RISK_FACTORY IN('TP','触控部')
             THEN 'TP'
             WHEN D.RISK_FACTORY IN('OLED','蒸镀封装部')
             THEN 'OLED'
             WHEN D.RISK_FACTORY IN('屏体部')
             THEN 'CELL'
             WHEN D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','TP','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')
             THEN '未分责'
             ELSE '开发责'
             END AS FACTORY
      , COALESCE (D.RISKCOMMENT ,'-') AS RISKCOMMENT
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.DTL_GRADE IN ('A','A1','A2')  THEN  D.OUTPUT_QTY ELSE 0 END) AS DFT_QTY 
  FROM DWS_YLD_WAREHOUSING_D_F D
 GROUP BY D.MONTH_TIMEKEY
      ,D.PROD_CODE 
      ,CASE WHEN D.RISK_FACTORY IN('ARRAY','阵列部')
             THEN 'ARRAY'
             WHEN D.RISK_FACTORY IN('TP','触控部')
             THEN 'TP'
              WHEN D.RISK_FACTORY IN('OLED','蒸镀封装部')
             THEN 'OLED'
             WHEN D.RISK_FACTORY IN('屏体部')
             THEN 'CELL'
             WHEN D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','TP','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')
             THEN '未分责'
             ELSE '开发责'
             END 
      ,COALESCE (D.RISKCOMMENT ,'-')
UNION ALL 
SELECT 'WEEK' AS DATE_TYPE
      ,D.WEEK_TIMEKEY AS DATE_VALUE
      ,D.PROD_CODE 
      ,CASE WHEN D.RISK_FACTORY IN('ARRAY','阵列部')
             THEN 'ARRAY'
             WHEN D.RISK_FACTORY IN('TP','触控部')
             THEN 'TP'
              WHEN D.RISK_FACTORY IN('OLED','蒸镀封装部')
             THEN 'OLED'
             WHEN D.RISK_FACTORY IN('屏体部')
             THEN 'CELL'
             WHEN D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','TP','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')
             THEN '未分责'
             ELSE '开发责'
             END AS FACTORY 
      , COALESCE (D.RISKCOMMENT ,'-') AS RISKCOMMENT
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.DTL_GRADE IN ('A','A1','A2')  THEN  D.OUTPUT_QTY ELSE 0 END) AS DFT_QTY 
  FROM DWS_YLD_WAREHOUSING_D_F D 
 GROUP BY D.WEEK_TIMEKEY 
      ,D.PROD_CODE 
      ,CASE WHEN D.RISK_FACTORY IN('ARRAY','阵列部')
             THEN 'ARRAY'
             WHEN D.RISK_FACTORY IN('TP','触控部')
             THEN 'TP'
             WHEN D.RISK_FACTORY IN('OLED','蒸镀封装部')
             THEN 'OLED'
             WHEN D.RISK_FACTORY IN('屏体部')
             THEN 'CELL'
             WHEN D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','TP','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')
             THEN '未分责'
             ELSE '开发责'
             END  
      ,COALESCE (D.RISKCOMMENT ,'-')
UNION ALL 
SELECT 'DAY' AS DATE_TYPE
      ,D.DATE_TIMEKEY AS DATE_VALUE
      ,D.PROD_CODE 
      ,CASE WHEN D.RISK_FACTORY IN('ARRAY','阵列部')
             THEN 'ARRAY'
             WHEN D.RISK_FACTORY IN('TP','触控部')
             THEN 'TP'
              WHEN D.RISK_FACTORY IN('OLED','蒸镀封装部')
             THEN 'OLED'
             WHEN D.RISK_FACTORY IN('屏体部')
             THEN 'CELL'
             WHEN D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','TP','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')
             THEN '未分责'
             ELSE '开发责'
             END  AS FACTORY 
      , COALESCE (D.RISKCOMMENT ,'-') AS RISKCOMMENT
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND D.DTL_GRADE IN ('A','A1','A2')  THEN  D.OUTPUT_QTY ELSE 0 END) AS DFT_QTY 
  FROM DWS_YLD_WAREHOUSING_D_F D
 GROUP BY D.DATE_TIMEKEY 
      ,D.PROD_CODE 
      ,CASE WHEN D.RISK_FACTORY IN('ARRAY','阵列部')
             THEN 'ARRAY'
             WHEN D.RISK_FACTORY IN('TP','触控部')
             THEN 'TP'
              WHEN D.RISK_FACTORY IN('OLED','蒸镀封装部')
             THEN 'OLED'
             WHEN D.RISK_FACTORY IN('屏体部')
             THEN 'CELL'
             WHEN D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','TP','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')
             THEN '未分责'
             ELSE '开发责'
             END  
      ,COALESCE (D.RISKCOMMENT ,'-')
      ),
INLINE_SCRAP_INFO AS (
SELECT 'MONTH' AS DATE_TYPE
      ,S.MONTH_TIMEKEY AS DATE_VALUE
      ,S.PROD_CODE 
      ,SUM(S.SCRAP_PNL_QTY) AS INLINE_SCRAP_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('ARRAY') THEN S.SCRAP_PNL_QTY ELSE 0 END) A_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('TP') THEN S.SCRAP_PNL_QTY ELSE 0 END) T_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('OLED前段','OLED后段','OLED') THEN S.SCRAP_PNL_QTY ELSE 0 END) O_INLINE_S_QTY
  FROM DWS_INLINE_SCRAP_D S
 WHERE S.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
  AND S.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND S.PROD_CODE IN ('"+cmcbProdCode+"')")}
--   ${IF(LEN(cmcbProdSpec)=0,"","AND S.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND S.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
   ${IF(LEN(txtID) = 0,"", "AND S.SHEET_ID IN ('" + txtID + "')" )}  
   /*AND S.PROD_CODE = 'D17'
   AND S.SUB_PROD_TYPE = 'ESLC'*/
 GROUP BY S.MONTH_TIMEKEY
         ,S.PROD_CODE 
UNION ALL 
SELECT 'WEEK' AS DATE_TYPE
      ,S.WEEK_TIMEKEY AS DATE_VALUE
      ,S.PROD_CODE 
      ,SUM(S.SCRAP_PNL_QTY) AS INLINE_SCRAP_QTY
       ,SUM(CASE WHEN S.RESP_FACTORY IN ('ARRAY') THEN S.SCRAP_PNL_QTY ELSE 0 END) A_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('TP') THEN S.SCRAP_PNL_QTY ELSE 0 END) T_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('OLED前段','OLED后段','OLED') THEN S.SCRAP_PNL_QTY ELSE 0 END) O_INLINE_S_QTY
  FROM DWS_INLINE_SCRAP_D S
  WHERE S.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtWeek} WEEK' ,'YYYYMMDD')
  AND S.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND S.PROD_CODE IN ('"+cmcbProdCode+"')")}
--   ${IF(LEN(cmcbProdSpec)=0,"","AND S.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND S.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
--   ${IF(LEN(txtID) = 0,"", "AND S.SHEET_ID IN ('" + txtID + "')" )}  
   /*AND S.PROD_CODE = 'D17'
   AND S.SUB_PROD_TYPE = 'ESLC'*/
 GROUP BY S.WEEK_TIMEKEY 
         ,S.PROD_CODE 
UNION ALL 
SELECT 'DAY' AS DATE_TYPE
      ,S.DATE_TIMEKEY AS DATE_VALUE
      ,S.PROD_CODE 
      ,SUM(S.SCRAP_PNL_QTY) AS INLINE_SCRAP_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('ARRAY') THEN S.SCRAP_PNL_QTY ELSE 0 END) A_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('TP') THEN S.SCRAP_PNL_QTY ELSE 0 END) T_INLINE_S_QTY
      ,SUM(CASE WHEN S.RESP_FACTORY IN ('OLED前段','OLED后段','OLED') THEN S.SCRAP_PNL_QTY ELSE 0 END) O_INLINE_S_QTY
  FROM DWS_INLINE_SCRAP_D S
  WHERE S.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtDay} DAY' ,'YYYYMMDD')
  AND S.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND S.PROD_CODE IN ('"+cmcbProdCode+"')")}
--   ${IF(LEN(cmcbProdSpec)=0,"","AND S.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND S.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
   ${IF(LEN(txtID) = 0,"", "AND S.SHEET_ID IN ('" + txtID + "')" )}  
   /*AND S.PROD_CODE = 'D17'
   AND S.SUB_PROD_TYPE = 'ESLC'*/
 GROUP BY S.DATE_TIMEKEY 
         ,S.PROD_CODE 
)
,SHIP_QTY AS (
SELECT 'MONTH' AS DATE_TYPE
      ,D.MONTH_TIMEKEY AS DATE_VALUE
      ,D.PROD_CODE
      ,SUM(OUTPUT_QTY) AS SHIP_QTY --入库数
 FROM  DWS_YLD_WAREHOUSING_D D
 WHERE D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
  AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND D.PROD_CODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND D.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
 GROUP BY D.MONTH_TIMEKEY 
         ,D.PROD_CODE
 UNION ALL 
 SELECT 'WEEK' AS DATE_TYPE
      ,D.WEEK_TIMEKEY AS DATE_VALUE
      ,D.PROD_CODE
      ,SUM(OUTPUT_QTY) AS SHIP_QTY --入库数
 FROM  DWS_YLD_WAREHOUSING_D D
  WHERE D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtWeek} WEEK' ,'YYYYMMDD')
  AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND D.PROD_CODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND D.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
 GROUP BY D.WEEK_TIMEKEY 
         ,D.PROD_CODE
   UNION ALL 
   SELECT 'DAY' AS DATE_TYPE
      ,D.DATE_TIMEKEY AS DATE_VALUE
      ,D.PROD_CODE
      ,SUM(OUTPUT_QTY) AS SHIP_QTY --入库数
 FROM  DWS_YLD_WAREHOUSING_D D
 WHERE D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtDay} DAY' ,'YYYYMMDD')
  AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   ${IF(LEN(cmcbProdCode)=0,"","AND D.PROD_CODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND D.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
 GROUP BY D.DATE_TIMEKEY 
         ,D.PROD_CODE
)
SELECT T.DATE_TYPE
      ,T.DATE_VALUE 
      ,COALESCE(Y.PROD_CODE,S.PROD_CODE) AS PROD_CODE 
      ,COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0) AS FENMU
      ,COALESCE(P.SHIP_QTY,0) AS SHIP_QTY
      , COALESCE(Y.RISK_QTY,0) AS RISK_QTY
      ,COALESCE(S.INLINE_SCRAP_QTY,0) AS INLINE_SCRAP_QTY
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0) = 0 THEN 0
            ELSE Y.RISK_QTY/(COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0))
        END AS RISK_RATIO
      ,Y.A_RISK_AA1_QTY
      ,Y.T_RISK_AA1_QTY
      ,Y.O_RISK_AA1_QTY
      ,Y.C_RISK_AA1_QTY
      ,Y.Q_RISK_AA1_QTY
      ,Y.KFZ_RISK_AA1_QTY
      ,Y.RISK_AA1_QTY
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0) = 0 THEN 0
            ELSE Y.RISK_AA1_QTY/(COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0))
        END AS RISK_AA1_RATIO
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0) = 0 THEN 0
            ELSE Y.A_RISK_AA1_QTY/(COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0))
        END AS A_RISK_AA1_RATIO
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0) = 0 THEN 0
            ELSE Y.T_RISK_AA1_QTY/(COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0))
        END AS T_RISK_AA1_RATIO  
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0) = 0 THEN 0
            ELSE Y.O_RISK_AA1_QTY/(COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0))
        END AS O_RISK_AA1_RATIO
       ,CASE WHEN COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0) = 0 THEN 0
            ELSE Y.C_RISK_AA1_QTY/(COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0))
        END AS C_RISK_AA1_RATIO 
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0) = 0 THEN 0
            ELSE Y.Q_RISK_AA1_QTY/(COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0))
        END AS Q_RISK_AA1_RATIO
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0) = 0 THEN 0
            ELSE Y.KFZ_RISK_AA1_QTY/(COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0))
        END AS KFZ_RISK_AA1_RATIO
      ,S.A_INLINE_S_QTY
      ,S.T_INLINE_S_QTY
      ,S.O_INLINE_S_QTY
      ,D.FACTORY AS DFT_FACTORY
      ,D.RISKCOMMENT 
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0) = 0 THEN 0
            ELSE D.DFT_QTY/(COALESCE(P.SHIP_QTY,0) + COALESCE(S.INLINE_SCRAP_QTY,0))
        END AS DFT_RATIO
  FROM TIME_TAB T 		       
       LEFT JOIN YLD_INFO Y
              ON T.DATE_VALUE = Y.DATE_VALUE 
       LEFT JOIN INLINE_SCRAP_INFO S
              ON T.DATE_VALUE = S.DATE_VALUE
             AND Y.PROD_CODE = S.PROD_CODE
       LEFT JOIN DFT_INFO D
              ON Y.DATE_VALUE = D.DATE_VALUE 
             AND Y.PROD_CODE = D.PROD_CODE
             AND COALESCE(S.PROD_CODE,Y.PROD_CODE) = D.PROD_CODE
             AND COALESCE(S.DATE_VALUE,Y.DATE_VALUE) = D.DATE_VALUE
       LEFT JOIN SHIP_QTY P
              ON T.DATE_VALUE = P.DATE_VALUE
             AND Y.PROD_CODE = P.PROD_CODE
ORDER BY CASE WHEN T.DATE_TYPE = 'MONTH' THEN 1
              WHEN T.DATE_TYPE = 'WEEK' THEN 2
              ELSE 3
          END,
         T.DATE_VALUE
         ,COALESCE(Y.PROD_CODE,S.PROD_CODE)
         ,D.RISKCOMMENT ]]></Query>
