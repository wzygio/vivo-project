<TableData name="PRODUCTCODE" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="cmcbProdType"/>
<O>
<![CDATA[LTPS-中尺寸]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
WITH PRODTYPE AS (SELECT distinct prod_type,prod_code
FROM IMP_CT_YLD_TARGET_MONTH_HY
where 1=1
and prod_type is not null
ORDER BY prod_type,PROD_CODE)

SELECT
    B.PRODUCT_CODE
    ,A.prod_type
FROM
    DWR_MES_PRODUCTSPEC_V B
    LEFT JOIN PRODTYPE A
    ON B.PRODUCT_CODE=A.prod_code
where 1=1
${IF(LEN(cmcbProdType)=0,"","AND A.prod_type IN ('"+cmcbProdType+"')")}
GROUP BY
    B.PRODUCT_CODE
    ,A.prod_type
ORDER BY
    PRODUCT_CODE]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="PRODSPEC" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[D17]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
SELECT
    PROD_ID
FROM
    DWR_MES_PRODUCTSPEC_V
WHERE FACTORY = 'POSTCELL'
${IF(LEN(cmcbProdCode)=0,"","AND PRODUCT_CODE IN ('"+cmcbProdCode+"')")}
GROUP BY
    PROD_ID
ORDER BY
   PROD_ID]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="DATEINFO" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters/>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
SELECT MONTH_TIMEKEY AS DATE_VALUE
      ,TO_DATE(DATE_START_TIMEKEY,'YYYYMMDD') AS DATE_START_TIMEKEY
      ,TO_DATE(DATE_END_TIMEKEY,'YYYYMMDD') AS DATE_END_TIMEKEY 
  FROM DWD_CALENDAR 
 WHERE 1=1
   AND FACTORY = 'ARRAY' 
   AND TIME_TYPE = 'MONTH'
 GROUP BY MONTH_TIMEKEY
         ,DATE_START_TIMEKEY
         ,DATE_END_TIMEKEY
UNION ALL 
SELECT WEEK_TIMEKEY AS DATE_VALUE
      ,TO_DATE(DATE_START_TIMEKEY,'YYYYMMDD') AS DATE_START_TIMEKEY
      ,TO_DATE(DATE_END_TIMEKEY,'YYYYMMDD') AS DATE_END_TIMEKEY 
  FROM DWD_CALENDAR 
 WHERE 1=1
   AND FACTORY = 'ARRAY' 
   AND TIME_TYPE = 'WEEK'
 GROUP BY WEEK_TIMEKEY
         ,DATE_START_TIMEKEY
         ,DATE_END_TIMEKEY
UNION ALL 
SELECT DATE_TIMEKEY AS DATE_VALUE
      ,TO_DATE(DATE_START_TIMEKEY,'YYYYMMDD') AS DATE_START_TIMEKEY
      ,TO_DATE(DATE_END_TIMEKEY,'YYYYMMDD') AS DATE_END_TIMEKEY 
  FROM DWD_CALENDAR 
 WHERE 1=1
   AND FACTORY = 'ARRAY' 
   AND TIME_TYPE = 'DAY'
 GROUP BY DATE_TIMEKEY
         ,DATE_START_TIMEKEY
         ,DATE_END_TIMEKEY]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="SERACH_CT_RUKU_YLD" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[M559]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdSpec"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="txtWeek"/>
<O>
<![CDATA[3]]></O>
</Parameter>
<Parameter>
<Attributes name="dtDateTime"/>
<O>
<![CDATA[2025-03-03]]></O>
</Parameter>
<Parameter>
<Attributes name="txtMonth"/>
<O>
<![CDATA[2]]></O>
</Parameter>
<Parameter>
<Attributes name="txtDay"/>
<O>
<![CDATA[7]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
WITH TIME_TAB AS (
SELECT 'DAY' AS DATE_TYPE
       ,DATE_TIMEKEY AS DATE_VALUE
       ,ROW_NUMBER() OVER(ORDER BY DATE_TIMEKEY) AS RN
  FROM DWD_CALENDAR
 WHERE FACTORY = 'ARRAY'
   AND TIME_TYPE = 'DAY'
   AND DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   AND DATE_TIMEKEY > TO_CHAR(TO_DATE('${dtDateTime}','YYYY-MM-DD') - INTERVAL '${txtDay}DAY','YYYYMMDD')
--月周
UNION ALL
SELECT S.DATE_TYPE
      ,S.DATE_VALUE
      ,S.RN
  FROM(SELECT T.DATE_TYPE
             ,T.DATE_VALUE
             ,ROW_NUMBER() OVER(PARTITION BY T.DATE_TYPE ORDER BY T.DATE_VALUE DESC) AS RN
         FROM(-- 周(此处获取当前周之前的所有周)
              SELECT DISTINCT 'WEEK' AS DATE_TYPE
                    ,N.WEEK_TIMEKEY AS DATE_VALUE
                FROM DWD_CALENDAR N
               INNER JOIN(-- 当前日期所在周
                          SELECT WEEK_TIMEKEY
                            FROM DWD_CALENDAR
                           WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                             AND FACTORY = 'ARRAY'
                             AND TIME_TYPE = 'DAY'
                         ) M
                       ON M.WEEK_TIMEKEY >= N.WEEK_TIMEKEY -- 当前周往前推
               WHERE N.FACTORY = 'ARRAY'
                 AND N.TIME_TYPE = 'DAY'
               UNION ALL
               -- 月(此处获取当前月之前的所有月)
               SELECT DISTINCT 'MONTH' AS DATE_TYPE
                     ,N.MONTH_TIMEKEY AS DATE_VALUE
                 FROM DWD_CALENDAR N
                INNER JOIN(SELECT MONTH_TIMEKEY
                             FROM DWD_CALENDAR
                            WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                              AND FACTORY = 'ARRAY'
                              AND TIME_TYPE = 'DAY'
                           ) M
                        ON M.MONTH_TIMEKEY >= N.MONTH_TIMEKEY -- 当前月往前推
                WHERE N.FACTORY = 'ARRAY'
                  AND N.TIME_TYPE = 'DAY'
              ) T
      ) S
 WHERE RN <= (CASE DATE_TYPE WHEN 'MONTH' THEN CAST('${txtMonth}' AS INT) ELSE CAST('${txtWeek}' AS INT) END)),

PRODUCTTYPE AS(
SELECT distinct prod_type,prod_code
FROM IMP_CT_YLD_TARGET_MONTH_HY
where 1=1
and prod_type is not null
ORDER BY prod_type,PROD_CODE),

ct_yld_info AS (
         SELECT d.date_type,
                d.month_timekey AS date_value,
                d.month_timekey,
                d.prod_code,
                case WHEN sum(d.ct_wm_yld_fenmu) = 0::numeric THEN 0::numeric
                ELSE sum(d.ct_wm_yld_fenzi) / sum(d.ct_wm_yld_fenmu)
                END AS ct_yield,
                sum(d.ct_wm_yld_fenmu) AS ct_output
          FROM dws_yld_comprehensive_d_new d
          WHERE d.date_type::text = 'MONTH'::text 
            AND D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
            AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','') 
            AND d.sub_prod_type::text = 'ESLC'::text
            ${IF(LEN(cmcbProdCode)=0,"","AND d.PROD_CODE IN ('"+cmcbProdCode+"')")}
            ${IF(LEN(cmcbProdSpec)=0,"","AND d.PROD_ID IN ('"+cmcbProdSpec+"')")}
         GROUP BY d.date_type, d.month_timekey, d.prod_code
  UNION ALL
         SELECT d.date_type,
                d.week_timekey AS date_value,
                min(d.month_timekey::text) AS month_timekey,
                d.prod_code,
                case WHEN sum(d.ct_wm_yld_fenmu) = 0::numeric THEN 0::numeric
                ELSE sum(d.ct_wm_yld_fenzi) / sum(d.ct_wm_yld_fenmu)
                END AS ct_yield,
                sum(d.ct_wm_yld_fenmu) AS ct_output
           FROM dws_yld_comprehensive_d_new d
          WHERE d.date_type::text = 'WEEK'::text 
            AND D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtWeek} WEEK' ,'YYYYMMDD')
            AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
            AND d.sub_prod_type::text = 'ESLC'::text
            ${IF(LEN(cmcbProdCode)=0,"","AND d.PROD_CODE IN ('"+cmcbProdCode+"')")}
            ${IF(LEN(cmcbProdSpec)=0,"","AND d.PROD_ID IN ('"+cmcbProdSpec+"')")}
          GROUP BY d.date_type, d.week_timekey, d.prod_code
   UNION ALL
         SELECT d.date_type,
                d.date_timekey AS date_value,
                d.month_timekey,
                d.prod_code,
                case WHEN sum(d.ct_wm_yld_fenmu) = 0::numeric THEN 0::numeric
                ELSE sum(d.ct_wm_yld_fenzi) / sum(d.ct_wm_yld_fenmu)
                END AS ct_yield,
                sum(d.ct_wm_yld_fenmu) AS ct_output
           FROM dws_yld_comprehensive_d_new d
          WHERE d.date_type::text = 'DAY'::text 
            AND D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtDay} DAY' ,'YYYYMMDD')
            AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
            AND d.sub_prod_type::text = 'ESLC'::text
            ${IF(LEN(cmcbProdCode)=0,"","AND d.PROD_CODE IN ('"+cmcbProdCode+"')")}
            ${IF(LEN(cmcbProdSpec)=0,"","AND d.PROD_ID IN ('"+cmcbProdSpec+"')")}
          GROUP BY d.date_type, d.date_timekey, d.month_timekey, d.prod_code
        ), 
 yld_info AS (
         SELECT 'MONTH'::text AS date_type,
            d.month_timekey AS date_value,
            d.month_timekey,
            d.prod_code,
            sum(d.output_qty) AS ship_qty,
            sum(
                case WHEN d.risk_flag::text = 'Y'::text THEN 0::numeric
                    ELSE
                    CASE WHEN d.dtl_grade::text = ANY (ARRAY['A'::text, 'A1'::text,'A2'::text]A) THEN d.output_qty
                    ELSE 0::numeric
                    END
                    END) AS aa1_qty
           FROM dws_yld_warehousing_d d
          WHERE 1=1
           AND D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
           AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')          
           AND (d.sub_prod_type::text = ANY (ARRAY['ESLC'::character varying::text, 'LCFG'::character varying::text, 'P'::character varying::text, 'SLCFG'::character varying::text, 'SYZLC'::character varying::text]A))
           ${IF(LEN(cmcbProdCode)=0,"","AND d.PROD_CODE IN ('"+cmcbProdCode+"')")}
            ${IF(LEN(cmcbProdSpec)=0,"","AND d.PROD_ID IN ('"+cmcbProdSpec+"')")}
          GROUP BY d.month_timekey, d.prod_code
 UNION ALL
         SELECT 'WEEK'::text AS date_type,
            d.week_timekey AS date_value,
            min(d.month_timekey::text) AS month_timekey,
            d.prod_code,
            sum(d.output_qty) AS ship_qty,
            sum(
                case WHEN d.risk_flag::text = 'Y'::text THEN 0::numeric
                    ELSE
                    case WHEN d.dtl_grade::text = ANY (ARRAY['A'::text, 'A1'::text,'A2'::text]A) THEN d.output_qty
                    ELSE 0::numeric
                    END
                END) AS aa1_qty
           FROM dws_yld_warehousing_d d
          WHERE 1=1
            AND D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtWeek} WEEK' ,'YYYYMMDD')
            AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
            AND (d.sub_prod_type::text = ANY (ARRAY['ESLC'::character varying::text, 'LCFG'::character varying::text, 'P'::character varying::text, 'SLCFG'::character varying::text, 'SYZLC'::character varying::text]A))
            ${IF(LEN(cmcbProdCode)=0,"","AND d.PROD_CODE IN ('"+cmcbProdCode+"')")}
            ${IF(LEN(cmcbProdSpec)=0,"","AND d.PROD_ID IN ('"+cmcbProdSpec+"')")}
          GROUP BY d.week_timekey, d.prod_code
UNION ALL
         SELECT 'DAY'::text AS date_type,
            d.date_timekey AS date_value,
            d.month_timekey,
            d.prod_code,
            sum(d.output_qty) AS ship_qty,
            sum(
                case WHEN d.risk_flag::text = 'Y'::text THEN 0::numeric
                    ELSE
                    CASE WHEN d.dtl_grade::text = ANY (ARRAY['A'::text, 'A1'::text,'A2'::text]A) THEN d.output_qty
                         ELSE 0::numeric
                         END
                END) AS aa1_qty
           FROM dws_yld_warehousing_d d
          WHERE 1=1
            AND D.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtDay} DAY' ,'YYYYMMDD')
            AND D.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
            AND (d.sub_prod_type::text = ANY (ARRAY['ESLC'::character varying::text, 'LCFG'::character varying::text, 'P'::character varying::text, 'SLCFG'::character varying::text, 'SYZLC'::character varying::text]A))
            ${IF(LEN(cmcbProdCode)=0,"","AND d.PROD_CODE IN ('"+cmcbProdCode+"')")}
            ${IF(LEN(cmcbProdSpec)=0,"","AND d.PROD_ID IN ('"+cmcbProdSpec+"')")}
          GROUP BY d.date_timekey, d.prod_code, d.month_timekey
        ),              
 inline_scrap_info AS (
     SELECT 'MONTH'::text AS date_type,
            s.month_timekey AS date_value,
            s.prod_code,
            sum(s.scrap_pnl_qty) AS inline_scrap_qty
           FROM dws_inline_scrap_d s
          WHERE 1=1
            AND S.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtMonth} MONTH' ,'YYYYMMDD')
            AND S.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
            AND (s.sub_prod_type::text = ANY (ARRAY['ESLC'::character varying::text, 'LCFG'::character varying::text, 'P'::character varying::text, 'SLCFG'::character varying::text, 'SYZLC'::character varying::text]A)) AND s.factory::text <> 'POSTCELL'::text
            ${IF(LEN(cmcbProdCode)=0,"","AND s.PROD_CODE IN ('"+cmcbProdCode+"')")}
            ${IF(LEN(cmcbProdSpec)=0,"","AND s.PROD_ID IN ('"+cmcbProdSpec+"')")}
          GROUP BY s.month_timekey, s.prod_code
UNION ALL
         SELECT 'WEEK'::text AS date_type,
            s.week_timekey AS date_value,
            s.prod_code,
            sum(s.scrap_pnl_qty) AS inline_scrap_qty
           FROM dws_inline_scrap_d s
          WHERE 1=1
            AND S.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtWeek} WEEK' ,'YYYYMMDD')
            AND S.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
            AND (s.sub_prod_type::text = ANY (ARRAY['ESLC'::character varying::text, 'LCFG'::character varying::text, 'P'::character varying::text, 'SLCFG'::character varying::text, 'SYZLC'::character varying::text]A)) AND s.factory::text <> 'POSTCELL'::text
            ${IF(LEN(cmcbProdCode)=0,"","AND s.PROD_CODE IN ('"+cmcbProdCode+"')")}
            ${IF(LEN(cmcbProdSpec)=0,"","AND s.PROD_ID IN ('"+cmcbProdSpec+"')")}
          GROUP BY s.week_timekey, s.prod_code
UNION ALL
         SELECT 'DAY'::text AS date_type,
            s.date_timekey AS date_value,
            s.prod_code,
            sum(s.scrap_pnl_qty) AS inline_scrap_qty
           FROM dws_inline_scrap_d s
          WHERE 1=1 
           AND  S.DATE_TIMEKEY >= TO_CHAR('${dtDateTime}'::TIMESTAMP - INTERVAL '${txtDay} DAY' ,'YYYYMMDD')
           AND  S.DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','') 
             AND (s.sub_prod_type::text = ANY (ARRAY['ESLC'::character varying::text, 'LCFG'::character varying::text, 'P'::character varying::text, 'SLCFG'::character varying::text, 'SYZLC'::character varying::text]A)) AND s.factory::text <> 'POSTCELL'::text
            ${IF(LEN(cmcbProdCode)=0,"","AND s.PROD_CODE IN ('"+cmcbProdCode+"')")}
            ${IF(LEN(cmcbProdSpec)=0,"","AND s.PROD_ID IN ('"+cmcbProdSpec+"')")}
          GROUP BY s.date_timekey, s.prod_code
        ), 
 ruku_yld_info AS (
           SELECT y.date_type,
            y.date_value,
            y.month_timekey,
            'ESLC' AS sub_prod_type,
            COALESCE(y.prod_code, s.prod_code) AS prod_code,
            COALESCE(y.ship_qty, 0::numeric) + COALESCE(s.inline_scrap_qty, 0::numeric) AS fenmu,
            COALESCE(y.ship_qty, 0::numeric) AS ruku_output,
            COALESCE(s.inline_scrap_qty, 0::numeric) AS inline_scrap_qty,
            y.aa1_qty,
                CASE
                    WHEN (COALESCE(y.ship_qty, 0::numeric) + COALESCE(s.inline_scrap_qty, 0::numeric)) = 0::numeric THEN 0::numeric
                    ELSE y.aa1_qty / (COALESCE(y.ship_qty, 0::numeric) + COALESCE(s.inline_scrap_qty, 0::numeric))
                END AS ruku_yield
           FROM yld_info y
             LEFT JOIN inline_scrap_info s ON y.date_value::text = s.date_value::text AND y.prod_code::text = s.prod_code::text
        )
        
 select  Z1.date_type
       ,Z1.date_value
       ,Z1.month_timekey
       ,Z1.prod_code
       ,Z1.ct_yield_target
       ,Z1.ct_yield
       ,Z1.ct_output
       ,Z1.ruku_yield
       ,Z1.ruku_output
       ,Z1.fenmu
       ,Z1.inline_scrap_qty
       ,P.PROD_TYPE
       ,SUM(Z1.fenmu) OVER(PARTITION BY Z1.date_value) AS FENMU_ALL
       ,SUM(Z1.fenmu) OVER(PARTITION BY Z1.date_type,Z1.prod_code) AS FENMU_Total
 FROM (select 
        S.date_type
       ,S.date_value
       ,Z.month_timekey
       ,Z.prod_code
       ,Z.ct_yield_target
       ,Z.ct_yield
       ,Z.ct_output
       ,Z.ruku_yield
       ,Z.ruku_output
       ,Z.fenmu
       ,Z.inline_scrap_qty
--       ,SUM(Z.fenmu) OVER(PARTITION BY Z.date_value) AS FENMU_ALL
--       ,SUM(Z.fenmu) OVER(PARTITION BY Z.date_type,Z.prod_code) AS FENMU_Total
 from  TIME_TAB S
 LEFT JOIN 
   (SELECT COALESCE(c.date_type, r.date_type::character varying) AS date_type,
    COALESCE(c.date_value, r.date_value) AS date_value,
    COALESCE(c.month_timekey, r.month_timekey) AS month_timekey,
    COALESCE(c.prod_code, r.prod_code) AS prod_code,
    i.ptzh_yld_target AS ct_yield_target,
    c.ct_yield,
    c.ct_output,
    r.ruku_yield,
    r.ruku_output,
    r.fenmu,
    r.inline_scrap_qty,
    P.PROD_TYPE
   FROM ct_yld_info c
     LEFT JOIN imp_ct_yld_target_month_hy i 
     ON c.month_timekey::text = replace(i.month_timekey::text, '-'::text, 'M'::text) 
     AND c.prod_code::text = i.prod_code::text
     LEFT JOIN PRODUCTTYPE P
     ON c.prod_code=P.PROD_CODE
     FULL JOIN ruku_yld_info r 
     ON c.date_value::text = r.date_value::text 
     AND c.prod_code::text = r.prod_code::text) Z
  ON S.date_value=Z.date_value) Z1
  LEFT JOIN PRODUCTTYPE P
  ON Z1.prod_code=P.PROD_CODE]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="SERACH_DATA_CHAR" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="txtWeek"/>
<O>
<![CDATA[3]]></O>
</Parameter>
<Parameter>
<Attributes name="dtDateTime"/>
<O>
<![CDATA[2025-03-03]]></O>
</Parameter>
<Parameter>
<Attributes name="txtMonth"/>
<O>
<![CDATA[2]]></O>
</Parameter>
<Parameter>
<Attributes name="txtDay"/>
<O>
<![CDATA[7]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
-- 七天
SELECT DATE_TYPE,
DATE_VALUE,
case when DATE_VALUE='-' then '-'
when DATE_VALUE='- ' then '- '
ELSE substring(DATE_VALUE,5,4)  end as DATE_CHAR
,MONTH_TIMEKEY
,RN
FROM (
SELECT 'DAY' AS DATE_TYPE
       ,DATE_TIMEKEY AS DATE_VALUE
       ,MONTH_TIMEKEY 
       ,ROW_NUMBER() OVER(ORDER BY DATE_TIMEKEY DESC ) AS RN
  FROM DWD_CALENDAR
 WHERE FACTORY = 'ARRAY'
   AND TIME_TYPE = 'DAY'
   AND DATE_TIMEKEY <= REPLACE('${dtDateTime}','-','')
   AND DATE_TIMEKEY >= TO_CHAR(TO_DATE('${dtDateTime}','YYYY-MM-DD') - INTERVAL '${txtDay}D'+INTERVAL'1D','YYYYMMDD')
-- 俩月三周
UNION ALL
SELECT S.DATE_TYPE
      ,S.DATE_VALUE
      ,S.MONTH_TIMEKEY
      ,S.RN
  FROM(SELECT T.DATE_TYPE
             ,T.DATE_VALUE
             ,T.MONTH_TIMEKEY 
             ,ROW_NUMBER() OVER(PARTITION BY T.DATE_TYPE ORDER BY T.DATE_VALUE DESC) AS RN
         FROM(-- 三周(此处获取当前周之前的所有周)
              SELECT DISTINCT 'WEEK' AS DATE_TYPE
                    ,N.WEEK_TIMEKEY AS DATE_VALUE
                    ,MIN(N.MONTH_TIMEKEY) as  MONTH_TIMEKEY
                FROM DWD_CALENDAR N
               INNER JOIN(-- 当前日期所在周
                          SELECT WEEK_TIMEKEY
                            FROM DWD_CALENDAR
                           WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                             AND FACTORY = 'ARRAY'
                             AND TIME_TYPE = 'DAY'
                         ) M
                       ON M.WEEK_TIMEKEY >= N.WEEK_TIMEKEY -- 当前周往前推
               WHERE N.FACTORY = 'ARRAY'
                 AND N.TIME_TYPE = 'DAY'
                 group by N.WEEK_TIMEKEY
               UNION ALL
               -- 俩月(此处获取当前月之前的所有月)
               SELECT DISTINCT 'MONTH' AS DATE_TYPE
                     ,N.MONTH_TIMEKEY AS DATE_VALUE
                     ,N.MONTH_TIMEKEY
                 FROM DWD_CALENDAR N
                INNER JOIN(SELECT MONTH_TIMEKEY
                             FROM DWD_CALENDAR
                            WHERE DATE_TIMEKEY = REPLACE('${dtDateTime}','-','')
                              AND FACTORY = 'ARRAY'
                              AND TIME_TYPE = 'DAY'
                           ) M
                        ON M.MONTH_TIMEKEY >= N.MONTH_TIMEKEY -- 当前月往前推
                WHERE N.FACTORY = 'ARRAY'
                  AND N.TIME_TYPE = 'DAY'
              ) T
      ) S
 WHERE RN <= (CASE DATE_TYPE WHEN 'MONTH' THEN ${txtMonth} ELSE ${txtWeek} END)
 union all 
 SELECT 'MONTH' AS DATE_TYPE
       ,'-' AS DATE_VALUE
       ,'-' ASMONTH_TIMEKEY 
       ,0 AS RN
union all 
 SELECT 'WEEK' AS DATE_TYPE
       ,'- ' AS DATE_VALUE
       ,'- ' AS MONTH_TIMEKEY 
       ,0  AS RN
 ) TIME_TAB
 WHERE 1=1
 ORDER BY CASE WHEN DATE_TYPE = 'MONTH' THEN 1
               WHEN DATE_TYPE = 'WEEK' THEN 2
          ELSE 3 END 
          ,RN  DESC 
          ]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="PRODUCTTYPE" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters/>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--V3入库不良率加权报表（徐敏杰-工艺整合大数据）
SELECT distinct prod_type,prod_code
FROM IMP_CT_YLD_TARGET_MONTH_HY
where 1=1
and prod_type is not null
ORDER BY prod_type,PROD_CODE]]></Query>
