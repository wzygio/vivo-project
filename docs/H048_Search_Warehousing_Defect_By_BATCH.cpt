<TableData name="SEARCH_RESTORE_YLD" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="txtID"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[C441\',\'N236]]></O>
</Parameter>
<Parameter>
<Attributes name="dtEndDate"/>
<O>
<![CDATA[2025-09-04]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbBatch"/>
<O>
<![CDATA[25/08/22蒸镀批]]></O>
</Parameter>
<Parameter>
<Attributes name="dtStartDate"/>
<O>
<![CDATA[2025-07-01]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[WITH BATCH_INFO AS(
SELECT '批次' AS DATE_TYPE
      ,T2.LOT
      ,T1. GLASS_ID 
      ,S.PRODUCTCODE 
--      ,MIN(T1.DATE_TIMEKEY) AS DATE_TIMEKEY
  FROM (SELECT PRODUCTREQUESTNAME
           ,CASE WHEN D.CREATETIME >= '20231201' THEN TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'YY/MM/DD') ,'YY/MM/DD') ||'蒸镀批'
             ELSE TO_CHAR(D.CREATETIME,'YY/')||TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'MM/DD') ,'MM/DD') ||'蒸镀批'
             END AS LOT
      FROM DWR_MES_PRODUCTREQUEST D
      WHERE D.SUBPRODUCTIONTYPE IN( 'ESLC','P')) T2
       LEFT JOIN DWT_INOUT_GLS T1
              ON T1.SUB_PROD_ID = T2.PRODUCTREQUESTNAME
             AND T1.OPER_CODE ='21200'
             AND INOUT_TYPE ='IN'
       LEFT JOIN DWR_MES_PRODUCTSPEC S
              ON T1.PROD_ID = S.PRODUCTSPECNAME 
 WHERE T1.SUB_PROD_TYPE IN ('ESLC','P','SLCFG','LCFG','SYZLC')
   AND T1.DATE_TIMEKEY >= TO_CHAR( '${dtStartDate}'::TIMESTAMP-INTERVAL '6 MONTH','YYYYMMDD')
   AND T1.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
   --AND T2.LOT IN ('05/08蒸镀批')
   --AND S.PRODUCTCODE='D36'
 ${IF(LEN(cmcbProdCode)=0,"","AND S.PRODUCTCODE IN ('"+cmcbProdCode+"')")}
 ${IF(LEN(cmcbBatch) = 0,"", "AND T2.LOT IN ('" + cmcbBatch + "')" )}
 GROUP BY T2.LOT
         ,T1.GLASS_ID 
         ,S.PRODUCTCODE
)
--,
--BATCH_DATA AS(
--SELECT B.PRODUCTCODE||'-'||B.LOT AS N_LOT
--      ,B.LOT AS LOT
--      ,MIN(D.DATE_TIMEKEY) AS DATE_TIMEKEY
--  FROM BATCH_INFO B
--       INNER JOIN DWS_YLD_WAREHOUSING_D D
--               ON B.GLASS_ID = D.GLASS_ID
-- WHERE D.DATE_TIMEKEY >= REPLACE('${dtStartDate}','-','')
--   AND D.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
-- GROUP BY B.PRODUCTCODE||'-'||B.LOT,B.LOT
--)
SELECT '批次' AS DATE_TYPE
	  ,T.LOT AS DATE_VALUE
      ,A.PROD_CODE
      ,COALESCE(A.FACTORY,'未分责') AS FACTORY
      ,SUM(A.DFT_QTY) AS GROUP_DFT_TY
      ,SUM(CASE WHEN A.RISK_FLAG <> 'Y' THEN A.DFT_QTY ELSE 0 END) AS NOT_RISK_DFT_QTY 
  FROM BATCH_INFO T
       INNER JOIN 
       (SELECT W.PROD_CODE
		      ,DECODE(G.FACTORY,'TP','TP','CELL','OLED',G.FACTORY) 
		      ,W.PANEL_ID
		      ,W.RISK_FLAG 
		      ,1 AS DFT_QTY
		  FROM DWS_DFT_WAREHOUSING_D W
		       LEFT JOIN IMP_CT_DFT_GROUP G
		              ON W.DEFECT_CODE = G.DEFECT_CODE
		       LEFT JOIN DWR_MES_PRODUCTSPEC P
		              ON W.PROD_ID = P.PRODUCTSPECNAME
		 WHERE W.DATE_TIMEKEY >= REPLACE('${dtStartDate}','-','')
		   AND W.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
             ${IF(LEN(cmcbProdCode)=0,"","AND W.PROD_CODE IN ('"+cmcbProdCode+"')")}
		   ${IF(LEN(txtID) = 0,"", "AND SUBSTR(S.PANEL_ID,1,11) IN ('" + txtID + "')" )} 
		 GROUP BY  W.PROD_CODE
			      ,G.FACTORY 
			      ,W.PANEL_ID
		          ,W.RISK_FLAG
	    ) A
	   ON SUBSTR(A.PANEL_ID,1,12) = T.GLASS_ID
 --WHERE A.FACTORY IS NOT NULL
 GROUP BY T.LOT
	     ,A.PROD_CODE
         ,A.FACTORY]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="PRODSPEC" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[D17]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[SELECT
    PROD_ID
FROM
    DWR_MES_PRODUCTSPEC_V
WHERE FACTORY = 'POSTCELL'
${IF(LEN(cmcbProdCode)=0,"","AND PRODUCT_CODE IN ('"+cmcbProdCode+"')")}
GROUP BY
    PROD_ID
ORDER BY
   PROD_ID]]></Query>
