<TableData name="SEARCH_RUKU" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="txtID"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[C441\',\'N236]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdSpec"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="dtEndDate"/>
<O>
<![CDATA[2025-09-03]]></O>
</Parameter>
<Parameter>
<Attributes name="dtStartDate"/>
<O>
<![CDATA[2025-07-01]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbBatch"/>
<O>
<![CDATA[25/08/22蒸镀批]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbSubProdType"/>
<O>
<![CDATA[]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[WITH BATCH_INFO AS(
SELECT '批次' AS DATE_TYPE
      ,T2.LOT
      ,T1. GLASS_ID 
      ,S.PRODUCTCODE 
--      ,MIN(T1.DATE_TIMEKEY) AS DATE_TIMEKEY
  FROM (SELECT PRODUCTREQUESTNAME
           ,CASE WHEN D.CREATETIME >= '20231201' THEN TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'YY/MM/DD') ,'YY/MM/DD') ||'蒸镀批'
             ELSE TO_CHAR(D.CREATETIME,'YY/')||TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'MM/DD') ,'MM/DD') ||'蒸镀批'
             END AS LOT
      FROM DWR_MES_PRODUCTREQUEST D
      WHERE D.SUBPRODUCTIONTYPE IN( 'ESLC','P')) T2
       LEFT JOIN DWT_INOUT_GLS T1
              ON T1.SUB_PROD_ID = T2.PRODUCTREQUESTNAME
             AND T1.OPER_CODE ='21200'
             AND INOUT_TYPE ='IN'
       LEFT JOIN DWR_MES_PRODUCTSPEC S
              ON T1.PROD_ID = S.PRODUCTSPECNAME 
 WHERE T1.SUB_PROD_TYPE IN ('ESLC','P','SLCFG','LCFG','SYZLC')
   AND T1.DATE_TIMEKEY >= TO_CHAR( '${dtStartDate}'::TIMESTAMP-INTERVAL '6 MONTH','YYYYMMDD')
   AND T1.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
   --AND T2.LOT IN ('05/08蒸镀批')
   --AND S.PRODUCTCODE='D36'
 ${IF(LEN(cmcbProdCode)=0,"","AND S.PRODUCTCODE IN ('"+cmcbProdCode+"')")}
 ${IF(LEN(cmcbBatch) = 0,"", "AND T2.LOT IN ('" + cmcbBatch + "')" )}
 GROUP BY T2.LOT
         ,T1.GLASS_ID 
         ,S.PRODUCTCODE
),
BATCH_DATA AS(
SELECT D.PROD_CODE||'-'||B.LOT AS N_LOT
      ,B.LOT AS LOT
      ,D.PROD_CODE
      ,MIN(D.DATE_TIMEKEY) AS DATE_TIMEKEY
  FROM BATCH_INFO B
       INNER JOIN DWS_YLD_WAREHOUSING_D D
               ON B.GLASS_ID = D.GLASS_ID
 WHERE D.DATE_TIMEKEY >= REPLACE('${dtStartDate}','-','')
   AND D.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
 GROUP BY D.PROD_CODE||'-'||B.LOT,B.LOT,D.PROD_CODE
 )
,DWS_YLD_WAREHOUSING_D AS(
SELECT  T.MONTH_TIMEKEY 
       ,T.WEEK_TIMEKEY 
       ,T.DATE_TIMEKEY 
       ,T.PROD_CODE 
       ,T.PROD_ID 
       ,T.SUB_PROD_TYPE 
       ,T.SUB_PROD_ID
       ,T.PANEL_GRADE 
       ,DTL_GRADE
       ,T.OUTPUT_QTY
       ,T.SHEET_ID 
       ,T.GLASS_ID
       ,T.RP_FLAG 
       ,T.RP_FACTORY 
       ,T.RISK_FLAG 
       ,T.INVENTORYCODE 
       ,DECODE(R.RISK_FACTORY ,'',T.RISK_FACTORY,NULL,T.RISK_FACTORY,R.RISK_FACTORY ) AS RISK_FACTORY
       ,T.A1_SHIP_FLAG
FROM (
      SELECT D.MONTH_TIMEKEY 
            ,D.WEEK_TIMEKEY 
            ,D.DATE_TIMEKEY 
            ,D.PROD_CODE 
            ,D.PROD_ID 
            ,D.SUB_PROD_TYPE 
            ,D.SUB_PROD_ID
            ,D.PANEL_GRADE 
            ,COALESCE(D.DTL_GRADE,'S') AS DTL_GRADE
            ,D.OUTPUT_QTY
            ,D.SHEET_ID 
            ,D.GLASS_ID
            ,D.RP_FLAG 
            ,D.RP_FACTORY 
            ,D.RISK_FLAG 
            ,D.INVENTORYCODE 
            ,CASE WHEN D.RISKCOMMENT ='AVI漏检风险 沈祥/未分责'
                  THEN SPLIT_PART(SPLIT_PART(D.RISKCOMMENT,' ',2),'/',2)
                  ELSE SPLIT_PART(SPLIT_PART(D.RISKCOMMENT,'-',2),'/',2) END AS RISK_FACTORY
            ,CASE WHEN D.DATE_TIMEKEY >= '20221127' AND D.DTL_GRADE = 'A1' THEN 'Y' ELSE D.A1_SHIP_FLAG  END AS A1_SHIP_FLAG --11月27日后A1全部算为良品，不再卡控是否出货，11月27日前保持A1出货为良品
       FROM DWS_YLD_WAREHOUSING_D D
      WHERE D.DATE_TIMEKEY >= REPLACE('${dtStartDate}','-','')
        AND D.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
        AND D.SUB_PROD_TYPE IN ('ESLC','P','SLCFG','LCFG','SYZLC')
   ${IF(LEN(cmcbProdCode)=0,"","AND D.PROD_CODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(cmcbSubProdType) = 0,"", "AND D.SUB_PROD_TYPE IN ('" + cmcbSubProdType + "')" )}
   ${IF(LEN(txtID) = 0,"", "AND D.SHEET_ID IN ('" + txtID + "')" )}  
          ) T  
     LEFT JOIN IMP_RUKU_RISK_DUTY R 
            ON T.PROD_CODE=R.PROD_CODE 
           AND T.SUB_PROD_ID=R.SUB_PROD_ID 
           )
,YLD_INFO AS(
SELECT B.LOT
      ,D.PROD_CODE 
      ,SUM(D.OUTPUT_QTY) AS SHIP_QTY --入库数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' THEN 0 ELSE CASE WHEN G.GRADE_FLAG ='Y' OR (D.DTL_GRADE = 'A1' AND D.A1_SHIP_FLAG = 'Y') THEN D.OUTPUT_QTY ELSE 0 END END ) AS AA1_QTY --良品数
      ,SUM(CASE WHEN D.RISK_FLAG <> 'Y' AND (G.GRADE_FLAG ='N'OR PANEL_GRADE='S' OR (D.DTL_GRADE = 'A1' AND D.A1_SHIP_FLAG = 'N')) THEN D.OUTPUT_QTY ELSE 0 END) AS NOT_RISK_DFT_QTY --非风险品不良数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' THEN D.OUTPUT_QTY ELSE 0 END) AS RISK_AA1_QTY --风险品AA1数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND R.RISK_FACTORY IN ('ARRAY','ARRAY+OLED') THEN (CASE WHEN R.RISK_FACTORY = 'ARRAY+OLED' THEN D.OUTPUT_QTY*0.5 ELSE D.OUTPUT_QTY END) ELSE 0 END) AS A_RISK_AA1_QTY --风险品AA1的ARRAY责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND R.RISK_FACTORY IN ('OLED','ARRAY+OLED') THEN (CASE WHEN R.RISK_FACTORY = 'ARRAY+OLED' THEN D.OUTPUT_QTY*0.5 ELSE D.OUTPUT_QTY END) ELSE 0 END) AS O_RISK_AA1_QTY --风险品AA1的OLED责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND (D.RISK_FACTORY IS NULL OR D.RISK_FACTORY = ''OR D.RISK_FACTORY = '未分责') THEN D.OUTPUT_QTY ELSE 0 END) AS Q_RISK_AA1_QTY --风险品AA1未分责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND R.RISK_FACTORY IN ('ARRAY','ARRAY+OLED') THEN D.OUTPUT_QTY ELSE 0 END) AS A_RISK_QTY --ARRAY责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y 'AND R.RISK_FACTORY IN ('OLED','ARRAY+OLED') THEN D.OUTPUT_QTY ELSE 0 END) AS O_RISK_QTY --ARRAY责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND R.RISK_FACTORY='开发责'  THEN D.OUTPUT_QTY ELSE 0 END) AS KFZ_RISK_AA1_QTY --开发责风险品AA1数
  FROM BATCH_INFO B 
  LEFT JOIN DWS_YLD_WAREHOUSING_D D 
              ON B.GLASS_ID = D.GLASS_ID
  LEFT JOIN IMP_RUKU_RISK_DUTY R
         ON D.PROD_CODE = R.PROD_CODE 
        AND D.SUB_PROD_ID = R.SUB_PROD_ID 
  LEFT JOIN IMP_YLD_GRADE_FLAG G 
         ON D.DTL_GRADE=G.GRADE 
WHERE 1=1 
AND D.SUB_PROD_TYPE IN ('ESLC','P','SLCFG','LCFG','SYZLC')
 GROUP BY  B.LOT
	     ,D.PROD_CODE  	  
)
,DFT_INFO AS(
SELECT B.LOT
      ,D.PROD_CODE 
      ,COALESCE(G.FACTORY,'/') AS FACTORY
      ,COALESCE(G.DEFECT_GROUP,'/') AS DEFECT_GROUP 
      ,D.DEFECT_CODE
      ,COALESCE(G.DEFECT_DESC,D.DEFECT_CODE) AS DEFECT_DESC  
      ,SUM(D.DFT_QTY) AS DFT_QTY 
  FROM BATCH_INFO B
  LEFT JOIN DWS_DFT_WAREHOUSING_D D
         ON B.GLASS_ID =D.GLASS_ID 
  LEFT JOIN IMP_CT_DFT_GROUP G
         ON D.DEFECT_CODE = G.DEFECT_CODE 
 WHERE 1=1
   AND D.DATE_TIMEKEY >= REPLACE('${dtStartDate}','-','')
   AND D.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
   AND D.SUB_PROD_TYPE IN ('ESLC','P','SLCFG','LCFG','SYZLC')
   ${IF(LEN(cmcbProdCode)=0,"","AND D.PROD_CODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(txtID) = 0,"", "AND D.SHEET_ID IN ('" + txtID + "')" )} 
 GROUP BY B.LOT
         ,D.PROD_CODE 
         ,COALESCE(G.FACTORY,'/') 
         ,COALESCE(G.DEFECT_GROUP,'/')
         ,D.DEFECT_CODE
         ,COALESCE(G.DEFECT_DESC,D.DEFECT_CODE)
)
SELECT '批次' AS DATE_TYPE
      ,T.LOT AS DATE_VALUE
      ,Y.PROD_CODE
      ,COALESCE(Y.SHIP_QTY,0) AS FENMU
      ,COALESCE(Y.SHIP_QTY,0) AS SHIP_QTY
      ,Y.AA1_QTY
      ,CASE WHEN COALESCE(Y.SHIP_QTY,0)  = 0 THEN 0
            ELSE Y.AA1_QTY/COALESCE(Y.SHIP_QTY,0)
        END AS YLD_RATIO
      ,CASE WHEN COALESCE(Y.SHIP_QTY,0) = 0 THEN 0
            ELSE Y.NOT_RISK_DFT_QTY/COALESCE(Y.SHIP_QTY,0)
        END AS NOT_RISK_DFT_RATIO
      ,CASE WHEN COALESCE(Y.SHIP_QTY,0)  = 0 THEN 0
            ELSE Y.RISK_AA1_QTY/COALESCE(Y.SHIP_QTY,0) 
        END AS RISK_AA1_RATIO
      ,Y.A_RISK_AA1_QTY
      ,Y.O_RISK_AA1_QTY
      ,Y.Q_RISK_AA1_QTY
      ,CASE WHEN COALESCE(Y.SHIP_QTY,0) = 0 THEN 0
            ELSE Y.A_RISK_AA1_QTY/COALESCE(Y.SHIP_QTY,0)
        END AS A_RISK_AA1_RATIO
      ,CASE WHEN COALESCE(Y.SHIP_QTY,0) = 0 THEN 0
            ELSE Y.O_RISK_AA1_QTY/COALESCE(Y.SHIP_QTY,0)
        END AS O_RISK_AA1_RATIO
      ,CASE WHEN COALESCE(Y.SHIP_QTY,0)  = 0 THEN 0
            ELSE Y.Q_RISK_AA1_QTY/COALESCE(Y.SHIP_QTY,0)
        END AS Q_RISK_AA1_RATIO
      ,CASE WHEN COALESCE(Y.SHIP_QTY,0)  = 0 THEN 0
            ELSE Y.KFZ_RISK_AA1_QTY/COALESCE(Y.SHIP_QTY,0)
        END AS KFZ_RISK_AA1_RATIO
      ,Y.A_RISK_QTY
      ,Y.O_RISK_QTY
      ,D.FACTORY AS DFT_FACTORY
      ,D.DEFECT_GROUP||';'||D.DEFECT_DESC AS DEFECT_DESC
      ,D.DEFECT_CODE 
      ,CASE WHEN COALESCE(Y.SHIP_QTY,0) = 0 THEN 0
            ELSE D.DFT_QTY/COALESCE(Y.SHIP_QTY,0)
        END AS DFT_RATIO
  FROM BATCH_DATA T 		       
       LEFT JOIN YLD_INFO Y
              ON T.LOT = Y.LOT 
             AND T.PROD_CODE=Y.PROD_CODE
       LEFT JOIN DFT_INFO D
              ON Y.LOT = D.LOT 
             AND Y.PROD_CODE = D.PROD_CODE             
ORDER BY T.DATE_TIMEKEY,T.LOT,Y.PROD_CODE]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="SEARCH_GROUP" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="txtID"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[N236]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdSpec"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="dtEndDate"/>
<O>
<![CDATA[2025-09-18]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbBatch"/>
<O>
<![CDATA[25/05/13蒸镀批]]></O>
</Parameter>
<Parameter>
<Attributes name="dtStartDate"/>
<O>
<![CDATA[2025-05-01]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[WITH BATCH_INFO AS(
SELECT '批次' AS DATE_TYPE
      ,T2.LOT
      ,T1. GLASS_ID 
      ,S.PRODUCTCODE 
--      ,MIN(T1.DATE_TIMEKEY) AS DATE_TIMEKEY
  FROM (SELECT PRODUCTREQUESTNAME
             ,CASE WHEN D.CREATETIME >= '20231201' THEN TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'YY/MM/DD') ,'YY/MM/DD') ||'蒸镀批'
             ELSE TO_CHAR(D.CREATETIME,'YY/')||TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'MM/DD') ,'MM/DD') ||'蒸镀批'
             END AS LOT
         FROM DWR_MES_PRODUCTREQUEST D
        WHERE D.SUBPRODUCTIONTYPE IN( 'ESLC','P')) T2
       LEFT JOIN DWT_INOUT_GLS T1
              ON T1.SUB_PROD_ID = T2.PRODUCTREQUESTNAME
             AND T1.OPER_CODE ='21200'
             AND INOUT_TYPE ='IN'
       LEFT JOIN DWR_MES_PRODUCTSPEC S
              ON T1.PROD_ID = S.PRODUCTSPECNAME 
 WHERE T1.SUB_PROD_TYPE IN ('ESLC','P','SLCFG','LCFG','SYZLC')
   AND T1.DATE_TIMEKEY >= TO_CHAR( '${dtStartDate}'::TIMESTAMP-INTERVAL '6 MONTH','YYYYMMDD')
   AND T1.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
   --AND T2.LOT IN ('05/08蒸镀批')
   --AND S.PRODUCTCODE='D36'
 ${IF(LEN(cmcbProdCode)=0,"","AND S.PRODUCTCODE IN ('"+cmcbProdCode+"')")}
 ${IF(LEN(cmcbBatch) = 0,"", "AND T2.LOT IN ('" + cmcbBatch + "')" )}
 GROUP BY T2.LOT
         ,T1.GLASS_ID 
         ,S.PRODUCTCODE
),BATCH_DATA AS(
SELECT D.PROD_CODE||'-'||B.LOT AS N_LOT
      ,B.LOT AS LOT
      ,D.PROD_CODE AS PRODUCTCODE
      ,MIN(D.DATE_TIMEKEY) AS DATE_TIMEKEY
  FROM BATCH_INFO B
       INNER JOIN DWS_YLD_WAREHOUSING_D D
               ON B.GLASS_ID = D.GLASS_ID
 WHERE D.DATE_TIMEKEY >= REPLACE('${dtStartDate}','-','')
   AND D.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
 GROUP BY D.PROD_CODE||'-'||B.LOT,B.LOT,D.PROD_CODE
)
SELECT '批次' AS DATE_TYPE
      ,T.LOT AS DATE_VALUE
      ,A.PROD_CODE
      ,G.DEFECT_GROUP
      ,SUM(A.DFT_QTY) AS GROUP_DFT_TY
  FROM BATCH_INFO T
       INNER JOIN (SELECT distinct I.DEFECT_GROUP FROM IMP_CT_DFT_GROUP I) G
              ON 1=1
       INNER JOIN (SELECT PRODUCTCODE FROM DWR_MES_PRODUCTSPEC WHERE 1=1 ${IF(LEN(cmcbProdCode)=0,"","AND PRODUCTCODE IN ('"+cmcbProdCode+"')")} GROUP BY PRODUCTCODE) P
              ON 1=1
       INNER JOIN 
       (SELECT W.PROD_CODE
		      ,G.DEFECT_GROUP 
		      ,W.PANEL_ID
		      ,1 AS DFT_QTY
		  FROM DWS_DFT_WAREHOUSING_D W
		       LEFT JOIN IMP_CT_DFT_GROUP G
		              ON W.DEFECT_CODE = G.DEFECT_CODE
		       LEFT JOIN DWR_MES_PRODUCTSPEC P
		              ON W.PROD_ID = P.PRODUCTSPECNAME
		 WHERE W.DATE_TIMEKEY >= REPLACE('${dtStartDate}','-','')
		   AND W.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
           ${IF(LEN(cmcbProdCode)=0,"","AND W.PROD_CODE IN ('"+cmcbProdCode+"')")}
		   ${IF(LEN(cmcbProdSpec)=0,"","AND W.PROD_ID IN ('"+cmcbProdSpec+"')")}
		   ${IF(LEN(txtID) = 0,"", "AND SUBSTR(W.PANEL_ID,1,11) IN ('" + txtID + "')" )} 
		 GROUP BY  W.PROD_CODE
			      ,G.DEFECT_GROUP 
			      ,W.PANEL_ID
	    ) A
	   ON T.GLASS_ID = SUBSTR(A.PANEL_ID,1,12) 
	  AND G.DEFECT_GROUP = A.DEFECT_GROUP
	  AND P.PRODUCTCODE = A.PROD_CODE
 GROUP BY T.LOT
	     ,A.PROD_CODE
	     ,G.DEFECT_GROUP
 ORDER BY T.LOT
	     ,A.PROD_CODE
         ,G.DEFECT_GROUP]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="DATEINFO" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters/>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[SELECT MONTH_TIMEKEY AS DATE_VALUE
      ,TO_DATE(DATE_START_TIMEKEY,'YYYYMMDD') AS DATE_START_TIMEKEY
      ,TO_DATE(DATE_END_TIMEKEY,'YYYYMMDD') AS DATE_END_TIMEKEY 
  FROM DWD_CALENDAR 
 WHERE 1=1
   AND FACTORY = 'ARRAY' 
   AND TIME_TYPE = 'MONTH'
 GROUP BY MONTH_TIMEKEY
         ,DATE_START_TIMEKEY
         ,DATE_END_TIMEKEY]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="SEARCH_RUKU_RISK" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="dtEndDate"/>
<O>
<![CDATA[2025-09-04]]></O>
</Parameter>
<Parameter>
<Attributes name="txtID"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[C441\',\'N236]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdSpec"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbBatch"/>
<O>
<![CDATA[25/08/22蒸镀批]]></O>
</Parameter>
<Parameter>
<Attributes name="dtStartDate"/>
<O>
<![CDATA[2025-07-04]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[WITH BATCH_INFO AS(
SELECT '批次' AS DATE_TYPE
      ,T2.LOT
      ,T1. GLASS_ID 
      ,S.PRODUCTCODE 
--      ,MIN(T1.DATE_TIMEKEY) AS DATE_TIMEKEY
  FROM (SELECT PRODUCTREQUESTNAME
           ,CASE WHEN D.CREATETIME >= '20231201' THEN TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'YY/MM/DD') ,'YY/MM/DD') ||'蒸镀批'
             ELSE TO_CHAR(D.CREATETIME,'YY/')||TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'MM/DD') ,'MM/DD') ||'蒸镀批'
             END AS LOT
      FROM DWR_MES_PRODUCTREQUEST D
      WHERE D.SUBPRODUCTIONTYPE IN( 'ESLC','P')) T2
       LEFT JOIN DWT_INOUT_GLS T1
              ON T1.SUB_PROD_ID = T2.PRODUCTREQUESTNAME
             AND T1.OPER_CODE ='21200'
             AND INOUT_TYPE ='IN'
       LEFT JOIN DWR_MES_PRODUCTSPEC S
              ON T1.PROD_ID = S.PRODUCTSPECNAME 
 WHERE T1.SUB_PROD_TYPE IN ('ESLC','P','SLCFG','LCFG','SYZLC')
   AND T1.DATE_TIMEKEY >= TO_CHAR( '${dtStartDate}'::TIMESTAMP-INTERVAL '6 MONTH','YYYYMMDD')
   AND T1.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
   --AND T2.LOT IN ('05/08蒸镀批')
   --AND S.PRODUCTCODE='D36'
 ${IF(LEN(cmcbProdCode)=0,"","AND S.PRODUCTCODE IN ('"+cmcbProdCode+"')")}
 ${IF(LEN(cmcbBatch) = 0,"", "AND T2.LOT IN ('" + cmcbBatch + "')" )}
 GROUP BY T2.LOT
         ,T1.GLASS_ID 
         ,S.PRODUCTCODE
),
BATCH_DATA AS(
SELECT D.PROD_CODE||'-'||B.LOT AS N_LOT
      ,B.LOT AS LOT
      ,D.PROD_CODE
      ,MIN(D.DATE_TIMEKEY) AS DATE_TIMEKEY
  FROM BATCH_INFO B
       INNER JOIN DWS_YLD_WAREHOUSING_D D
               ON B.GLASS_ID = D.GLASS_ID
 WHERE D.DATE_TIMEKEY >= REPLACE('${dtStartDate}','-','')
   AND D.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
 GROUP BY D.PROD_CODE||'-'||B.LOT,B.LOT,D.PROD_CODE
),
DWS_YLD_WAREHOUSING_D_F AS(
SELECT  G.MONTH_TIMEKEY 
       ,G.WEEK_TIMEKEY 
       ,G.DATE_TIMEKEY 
       ,G.PROD_CODE 
       ,G.PROD_ID 
       ,G.SUB_PROD_TYPE 
       ,G.SUB_PROD_ID
       ,G.PANEL_GRADE 
       ,G.DTL_GRADE
       ,CASE WHEN G.RISK_FACTORY='ARRAY+OLED'
             THEN G.OUTPUT_QTY/2
             ELSE G.OUTPUT_QTY
             END AS OUTPUT_QTY
       ,G.SHEET_ID 
       ,G.GLASS_ID
       ,G.RISK_FLAG 
       ,G.A1_SHIP_FLAG
       ,CASE WHEN G.RISK_FACTORY='ARRAY+OLED'
             THEN UNNEST(STRING_TO_ARRAY(G.RISK_FACTORY,'+') ) 
             ELSE G.RISK_FACTORY 
             END AS RISK_FACTORY 
	   ,G.RISKCOMMENT --风险品描述
FROM (            
SELECT  T.MONTH_TIMEKEY 
       ,T.WEEK_TIMEKEY 
       ,T.DATE_TIMEKEY 
       ,T.PROD_CODE 
       ,T.PROD_ID 
       ,T.SUB_PROD_TYPE 
       ,T.SUB_PROD_ID
       ,T.PANEL_GRADE 
       ,DTL_GRADE
       ,T.OUTPUT_QTY
       ,T.SHEET_ID 
       ,T.GLASS_ID
       ,T.RISK_FLAG 
		      ,CASE WHEN (T.RISK_FACTORY IS NOT NULL AND T.RISK_FACTORY <>'')
		            THEN  T.RISK_FACTORY
		            WHEN (T.RISK_FACTORY IS  NULL OR T.RISK_FACTORY ='') AND (R.RISK_FACTORY IS NOT NULL OR R.RISK_FACTORY <>'')
		            THEN R.RISK_FACTORY 
		            ELSE T.RISKFACTORY 
		            END AS RISK_FACTORY--风险品责任工厂
       ,CASE WHEN (T.RISK_DSC IS NOT NULL OR T.RISK_DSC <>'')
		            THEN  T.RISK_DSC
		            WHEN (T.RISK_DSC IS NULL  OR T.RISK_DSC ='') AND (R.RISK_COMMENT IS NOT NULL OR R.RISK_COMMENT <>'')
		            THEN R.RISK_COMMENT 
		            ELSE T.RISKCOMMENT 
		            END AS RISKCOMMENT --风险品描述
       ,T.A1_SHIP_FLAG
FROM (
      SELECT Y.MONTH_TIMEKEY 
            ,Y.WEEK_TIMEKEY 
            ,D.FIRST_SHIP_DATE AS DATE_TIMEKEY 
            ,P.PRODUCTCODE AS PROD_CODE 
            ,D.PROD_ID 
            ,R.SUBPRODUCTIONTYPE  AS SUB_PROD_TYPE 
            ,D.SUB_PROD_ID
            ,D.PANEL_GRADE 
            ,D.PANEL_ID 
            ,CASE WHEN D.DTL_GRADE IS NULL 
                  THEN 'S'
	              ELSE D.DTL_GRADE
	              END AS DTL_GRADE 
            ,SUM(D.OPER_OUT_PNL_QTY) AS OUTPUT_QTY
	        ,SUBSTR(D.PANEL_ID,1,11) AS SHEET_ID
	        ,SUBSTR(D.PANEL_ID,1,12) AS GLASS_ID
            ,D.RISK_FLAG  
            ,H.RISK_FACTORY 
            ,R.RISKFACTORY 
            ,R.RISKCOMMENT 
            ,H.RISK_DSC
            ,CASE WHEN D.FIRST_SHIP_DATE >= '20221127' AND D.DTL_GRADE = 'A1' 
                  THEN 'Y' 
                  ELSE D.A1_SHIP_FLAG  
                  END AS A1_SHIP_FLAG --11月27日后A1全部算为良品，不再卡控是否出货，11月27日前保持A1出货为良品
       FROM DWT_WAREHOUSING_PNL D
  LEFT JOIN DWD_CALENDAR Y
	     ON D.FIRST_SHIP_DATE = Y.TIME_KEY
	    AND Y.FACTORY = 'ARRAY'
  LEFT JOIN DWR_MES_PRODUCTSPEC P
	     ON D.PROD_ID = P.PRODUCTSPECNAME
  LEFT JOIN DWR_MES_PRODUCTREQUEST R
	     ON D.SUB_PROD_ID = R.PRODUCTREQUESTNAME  
	     LEFT JOIN (SELECT COALESCE(P1.PANEL_ID, P.PANEL_ID, A.LOTNAME) AS LOTNAME,
                    A.RISKFACTORY AS RISK_FACTORY ,
                   (A.RISKCODE::TEXT || ' '::TEXT) || COALESCE(T.DESCRIPTION, ''::CHARACTER VARYING)::TEXT AS RISK_DSC
                  FROM DWR_MES_CT_RISKHOLDPRODUCT A
             LEFT JOIN DWR_MES_PRODUCTSPEC_V B 
                    ON B.FACTORY::TEXT = 'POSTCELL'::TEXT 
                   AND SUBSTR(A.LOTNAME::TEXT, 3, 2) = B.OLD_PRODUCT_CODE::TEXT
             LEFT JOIN DWR_MES_PNL P 
                    ON A.LOTNAME::TEXT =LEFT(P.PANEL_ID::TEXT, 12) 
                   AND LENGTH(A.LOTNAME::TEXT) = 12
             LEFT JOIN DWR_MES_PNL P1 
                    ON A.LOTNAME::TEXT = LEFT(P1.PANEL_ID::TEXT, 11) 
                   AND LENGTH(A.LOTNAME::TEXT) = 11
              LEFT JOIN ( SELECT DESCRIPTION,
                                 REASONCODE
                            FROM DWR_MES_REASONCODE
                           WHERE DWR_MES_REASONCODE.REASONCODETYPE::TEXT = 'RiskHoldCode'::TEXT 
                           AND (DWR_MES_REASONCODE.AVAILABILITY::TEXT = ANY (ARRAY['Available'::TEXT, 'Availability'::TEXT]A)) 
                           AND DWR_MES_REASONCODE.SUPERREASONCODE IS NOT NULL) T
                   ON T.REASONCODE::TEXT = A.RISKCODE::TEXT
              GROUP BY COALESCE(P1.PANEL_ID, P.PANEL_ID, A.LOTNAME)
                       , A.RISKFACTORY
                        ,(A.RISKCODE::TEXT || ' '::TEXT) || COALESCE(T.DESCRIPTION, ''::CHARACTER VARYING)::TEXT
                        ,A.RISKDUTYUSER 
                        ,A.RISKDEPT ) H 
        ON D.PANEL_ID =H.LOTNAME
     WHERE D.FIRST_SHIP_DATE >= REPLACE('${dtStartDate}','-','')
       AND D.FIRST_SHIP_DATE <= REPLACE('${dtEndDate}','-','')
       AND D.DATE_TIMEKEY>=REPLACE('${dtStartDate}','-','')
--       AND P.PRODUCTCODE ='C20'
--       AND D.FIRST_SHIP_DATE >='20231224'
--       AND D.FIRST_SHIP_DATE <='20231230'
       AND R.SUBPRODUCTIONTYPE IN ('ESLC','P','LCFG','SLCFG','SYZLC')
--       AND D.RISK_FLAG ='Y'
   ${IF(LEN(cmcbProdCode)=0,"","AND P.PRODUCTCODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
   ${IF(LEN(txtID) = 0,"", "AND D.SUBSTR(D.PANEL_ID,1,11) IN ('" + txtID + "')" )}  
GROUP BY     Y.MONTH_TIMEKEY 
            ,Y.WEEK_TIMEKEY 
            ,D.OPER_OUT_PNL_QTY
            ,D.FIRST_SHIP_DATE 
            ,P.PRODUCTCODE  
            ,D.PROD_ID 
            ,D.PANEL_ID 
            ,R.SUBPRODUCTIONTYPE  
            ,D.SUB_PROD_ID
            ,D.PANEL_GRADE 
            ,CASE WHEN D.DTL_GRADE IS NULL 
                  THEN 'S'
	              ELSE D.DTL_GRADE
	              END  
	        ,SUBSTR(D.PANEL_ID,1,11) 
	        ,SUBSTR(D.PANEL_ID,1,12) 
            ,D.RISK_FLAG  
            ,H.RISK_FACTORY
            ,R.RISKFACTORY 
            ,CASE WHEN D.FIRST_SHIP_DATE >= '20221127' AND D.DTL_GRADE = 'A1' 
                  THEN 'Y' 
                  ELSE D.A1_SHIP_FLAG  
                  END
            ,R.RISKCOMMENT 
            ,H.RISK_DSC
          ) T  
 LEFT JOIN IMP_RUKU_RISK_DUTY R 
         ON T.PROD_CODE=R.PROD_CODE 
         AND T.SUB_PROD_ID=R.SUB_PROD_ID 
         ) G    
         )
,YLD_INFO AS(
SELECT B.LOT
      ,D.PROD_CODE 
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' THEN 0 ELSE CASE WHEN  G.GRADE_FLAG ='Y' OR (D.DTL_GRADE = 'A1' AND D.A1_SHIP_FLAG = 'Y') THEN D.OUTPUT_QTY ELSE 0 END END ) AS AA1_QTY --良品数
      ,SUM(CASE WHEN D.RISK_FLAG <> 'Y' AND (G.GRADE_FLAG ='N' OR PANEL_GRADE='S' OR (D.DTL_GRADE = 'A1' AND D.A1_SHIP_FLAG = 'N')) THEN D.OUTPUT_QTY ELSE 0 END) AS NOT_RISK_DFT_QTY --非风险品不良数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' THEN D.OUTPUT_QTY ELSE 0 END) AS RISK_AA1_QTY --风险品AA1数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('ARRAY','阵列部') THEN OUTPUT_QTY  ELSE 0 END) AS A_RISK_AA1_QTY --风险品AA1的ARRAY责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('TP','触控部') THEN OUTPUT_QTY  ELSE 0 END) AS T_RISK_AA1_QTY --风险品AA1的TP责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('OLED','蒸镀封装部') THEN D.OUTPUT_QTY ELSE 0 END) AS O_RISK_AA1_QTY --风险品AA1的OLED责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('屏体部') THEN D.OUTPUT_QTY ELSE 0 END) AS P_RISK_AA1_QTY --风险品AA1的CELL责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND (D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','TP','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')) THEN D.OUTPUT_QTY ELSE 0 END) AS Q_RISK_AA1_QTY --风险品AA1未分责
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('ARRAY','阵列部') THEN D.OUTPUT_QTY ELSE 0 END) AS A_RISK_QTY --ARRAY责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y 'AND D.RISK_FACTORY IN ('TP','触控部') THEN D.OUTPUT_QTY ELSE 0 END) AS T_RISK_QTY --TP责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND D.RISK_FACTORY IN ('OLED','蒸镀封装部','屏体部') THEN D.OUTPUT_QTY ELSE 0 END) AS O_RISK_QTY --OLED责风险品数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y' AND D.RISK_FACTORY='开发责' THEN D.OUTPUT_QTY ELSE 0 END) AS KFZ_RISK_AA1_QTY --开发责风险品AA1数
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y'  THEN  D.OUTPUT_QTY ELSE 0 END) AS RISK_QTY --风险品总数
  FROM BATCH_INFO B 
  LEFT JOIN DWS_YLD_WAREHOUSING_D_F D 
              ON B.GLASS_ID = D.GLASS_ID
  LEFT JOIN IMP_YLD_GRADE_FLAG G 
         ON D.DTL_GRADE=G.GRADE 
WHERE 1=1 
AND D.SUB_PROD_TYPE IN ('ESLC','P','SLCFG','LCFG','SYZLC')
 GROUP BY  B.LOT
	     ,D.PROD_CODE  	)
,DFT_INFO AS(
SELECT B.LOT
      ,D.PROD_CODE
      , CASE WHEN D.RISK_FACTORY IN('ARRAY','阵列部')
             THEN 'ARRAY'
             WHEN D.RISK_FACTORY IN('TP','触控部')
             THEN 'TP'
             WHEN D.RISK_FACTORY IN('OLED','蒸镀封装部')
             THEN 'OLED'
             WHEN D.RISK_FACTORY IN('屏体部')
             THEN 'CELL'
             WHEN D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','TP','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')
             THEN '未分责'
             ELSE '开发责'
             END AS FACTORY
      , COALESCE (D.RISKCOMMENT ,'-') AS RISKCOMMENT
      ,SUM(CASE WHEN D.RISK_FLAG = 'Y' AND G.GRADE_FLAG ='Y'  THEN  D.OUTPUT_QTY ELSE 0 END) AS DFT_QTY 
 FROM BATCH_INFO B 
  LEFT JOIN DWS_YLD_WAREHOUSING_D_F D 
              ON B.GLASS_ID = D.GLASS_ID
  LEFT JOIN IMP_YLD_GRADE_FLAG G 
         ON D.DTL_GRADE=G.GRADE 
 GROUP BY B.LOT
      ,D.PROD_CODE 
      , CASE WHEN D.RISK_FACTORY IN('ARRAY','阵列部')
             THEN 'ARRAY'
             WHEN D.RISK_FACTORY IN('TP','触控部')
             THEN 'TP'
             WHEN D.RISK_FACTORY IN('OLED','蒸镀封装部')
             THEN 'OLED'
             WHEN D.RISK_FACTORY IN('屏体部')
             THEN 'CELL'
             WHEN D.RISK_FACTORY IS NULL OR D.RISK_FACTORY NOT IN ('ARRAY','TP','OLED','阵列部','触控部','蒸镀封装部','屏体部','开发责')
             THEN '未分责'
             ELSE '开发责'
             END 
      ,COALESCE (D.RISKCOMMENT ,'-')
      )
,SHIP_QTY AS (
SELECT B.LOT
      ,D.PROD_CODE
      ,SUM(OUTPUT_QTY) AS SHIP_QTY --入库数
 FROM  BATCH_INFO B 
  LEFT JOIN DWS_YLD_WAREHOUSING_D D 
              ON B.GLASS_ID = D.GLASS_ID
 WHERE D.DATE_TIMEKEY >= REPLACE('${dtStartDate}','-','')
   AND D.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
   AND D.SUB_PROD_TYPE IN ('ESLC','P','SLCFG','LCFG','SYZLC')
   ${IF(LEN(cmcbProdCode)=0,"","AND D.PROD_CODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbProdSpec)=0,"","AND D.PROD_ID IN ('"+cmcbProdSpec+"')")}
 GROUP BY B.LOT
      ,D.PROD_CODE 
      )
SELECT '批次' AS DATE_TYPE
      ,T.LOT AS DATE_VALUE
      ,Y.PROD_CODE
      ,COALESCE(P.SHIP_QTY,0) AS FENMU
      ,COALESCE(P.SHIP_QTY,0) AS SHIP_QTY
      ,Y.AA1_QTY
      ,CASE WHEN COALESCE(P.SHIP_QTY,0)  = 0 THEN 0
            ELSE Y.AA1_QTY/COALESCE(P.SHIP_QTY,0)
        END AS YLD_RATIO
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) = 0 THEN 0
            ELSE Y.NOT_RISK_DFT_QTY/COALESCE(P.SHIP_QTY,0)
        END AS NOT_RISK_DFT_RATIO
      ,CASE WHEN COALESCE(P.SHIP_QTY,0)  = 0 THEN 0
            ELSE Y.RISK_AA1_QTY/COALESCE(P.SHIP_QTY,0) 
        END AS RISK_AA1_RATIO
      ,Y.RISK_AA1_QTY
      ,Y.A_RISK_AA1_QTY
      ,Y.T_RISK_AA1_QTY
      ,Y.O_RISK_AA1_QTY
      ,Y.Q_RISK_AA1_QTY
      ,Y.KFZ_RISK_AA1_QTY
      ,Y.P_RISK_AA1_QTY
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) = 0 THEN 0
            ELSE Y.A_RISK_AA1_QTY/COALESCE(P.SHIP_QTY,0)
        END AS A_RISK_AA1_RATIO
       ,CASE WHEN COALESCE(P.SHIP_QTY,0) = 0 THEN 0
            ELSE Y.T_RISK_AA1_QTY/COALESCE(P.SHIP_QTY,0)
        END AS T_RISK_AA1_RATIO 
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) = 0 THEN 0
            ELSE Y.O_RISK_AA1_QTY/COALESCE(P.SHIP_QTY,0)
        END AS O_RISK_AA1_RATIO
      ,CASE WHEN COALESCE(P.SHIP_QTY,0)  = 0 THEN 0
            ELSE Y.Q_RISK_AA1_QTY/COALESCE(P.SHIP_QTY,0)
        END AS Q_RISK_AA1_RATIO
      ,CASE WHEN COALESCE(P.SHIP_QTY,0)  = 0 THEN 0
            ELSE Y.KFZ_RISK_AA1_QTY/COALESCE(P.SHIP_QTY,0)
        END AS KFZ_RISK_AA1_RATIO
      ,Y.A_RISK_QTY
      ,Y.O_RISK_QTY
      ,D.FACTORY AS DFT_FACTORY
      ,D.RISKCOMMENT AS DEFECT_DESC
      ,CASE WHEN COALESCE(P.SHIP_QTY,0) = 0 THEN 0
            ELSE D.DFT_QTY/COALESCE(P.SHIP_QTY,0)
        END AS DFT_RATIO
  FROM BATCH_DATA T 		       
       LEFT JOIN YLD_INFO Y
              ON T.LOT = Y.LOT 
             AND T.PROD_CODE=Y.PROD_CODE
       LEFT JOIN DFT_INFO D
              ON Y.LOT = D.LOT 
             AND Y.PROD_CODE = D.PROD_CODE  
       LEFT JOIN SHIP_QTY P
              ON Y.LOT = P.LOT 
             AND Y.PROD_CODE = P.PROD_CODE 
ORDER BY T.DATE_TIMEKEY,T.LOT,Y.PROD_CODE]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="SEARCH_EVAQTY" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="dtEndDate"/>
<O>
<![CDATA[2024-02-26]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[C20]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbBatch"/>
<O>
<![CDATA[]]></O>
</Parameter>
<Parameter>
<Attributes name="dtStartDate"/>
<O>
<![CDATA[2024-02-01]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[--入库批次报表：蒸镀批次数量计算(吴文君)
WITH EVA_GLASS AS (
SELECT T1.GLASS_ID
      ,S.PRODUCTCODE AS PROD_CODE
      ,T2.LOT AS SUB_PROD_ID
      ,S.SUBPRODUCTUNITQUANTITY1
      ,COUNT(DISTINCT T1.GLASS_ID)OVER(PARTITION BY T2.LOT,S.PRODUCTCODE)*S.SUBPRODUCTUNITQUANTITY1/2 AS EVA_QTY
  FROM (SELECT PRODUCTREQUESTNAME
            ,CASE WHEN D.CREATETIME >= '20231201' THEN TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'YY/MM/DD') ,'YY/MM/DD') ||'蒸镀批'
             ELSE TO_CHAR(D.CREATETIME,'YY/')||TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'MM/DD') ,'MM/DD') ||'蒸镀批'
             END AS LOT
      FROM DWR_MES_PRODUCTREQUEST D
      WHERE D.SUBPRODUCTIONTYPE IN( 'ESLC','P')) T2
       INNER JOIN DWT_INPUT_GLS T1
              ON T1.SUB_PROD_ID = T2.PRODUCTREQUESTNAME
             AND T1.OPER_CODE ='21200'
             AND T1.DATE_TIMEKEY >= TO_CHAR('${dtStartDate}'::TIMESTAMP - INTERVAL '3 MONTH','YYYYMMDD')
             AND T1.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
       INNER JOIN DWR_MES_PRODUCTSPEC S
              ON T1.PROD_ID = S.PRODUCTSPECNAME 
 WHERE T1.SUB_PROD_TYPE IN( 'ESLC','P')
--   AND T2.LOT IN ('23/11/01蒸镀批')
   ${IF(LEN(cmcbProdCode)=0,"","AND S.PRODUCTCODE IN ('"+cmcbProdCode+"')")}
   ${IF(LEN(cmcbBatch)=0,"","AND T2.LOT IN ('"+cmcbBatch+"')")}
 GROUP BY T1.GLASS_ID,T2.LOT,S.SUBPRODUCTUNITQUANTITY1,S.PRODUCTCODE
),
OLED_TP_SY_OUTOUT AS (
SELECT O.GLASS_ID 
	  ,O.OUTPUT_PNL_QTY
	  ,O.CANCEL_OUTPUT_PNL_QTY
	  ,O.EVENT_NAME
	  ,O.SUB_PROD_TYPE
	  ,ROW_NUMBER()OVER(PARTITION BY O.GLASS_ID ORDER BY EVENT_TIMEKEY DESC) AS RN
  FROM EVA_GLASS E 
       INNER JOIN DWT_OUTPUT_GLS O
              ON E.GLASS_ID = O.GLASS_ID 
 WHERE O.DATE_TIMEKEY >= TO_CHAR('${dtStartDate}'::TIMESTAMP - INTERVAL '3 MONTH','YYYYMMDD')
   AND O.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
),
PC_SY_OUTPUT AS (
SELECT SUBSTR(A.PANEL_ID,1,12) AS GLASS_ID
      ,SUM(A.OUTPUT_ALL_PNL_QTY) AS BEHIND_EVA_PC_SY_QTY
  FROM (SELECT O.PANEL_ID 
		      ,O.OUTPUT_ALL_PNL_QTY
		      ,O.SUB_PROD_TYPE 
		      ,O.EVENT_NAME
		      ,ROW_NUMBER()OVER(PARTITION BY O.PANEL_ID ORDER BY EVENT_TIMEKEY DESC) AS RN
		  FROM DWT_OUTPUT_PNL O
		 WHERE O.SUB_PROD_TYPE NOT IN ('ESLC','P','LCFG','SLCFG','SYZLC')
		   AND O.PROD_TYPE = 'E'
		   AND O.DATE_TIMEKEY >= TO_CHAR('${dtStartDate}'::TIMESTAMP - INTERVAL '1 MONTH','YYYYMMDD')
		   AND O.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','') 
		   AND SUBSTR(O.PANEL_ID,1,12) IN (SELECT O.GLASS_ID FROM OLED_TP_SY_OUTOUT O WHERE O.SUB_PROD_TYPE IN ('ESLC','P') AND O.RN = 1)
		) A   
 WHERE A.RN = 1
   AND A.OUTPUT_ALL_PNL_QTY > 0
 GROUP BY SUBSTR(A.PANEL_ID,1,12)
 )
SELECT E.PROD_CODE
      ,E.SUB_PROD_ID
      ,E.EVA_QTY
      ,SUM(CASE WHEN S.SCRAP_TYPE = 'Scrap' AND S.SUB_PROD_TYPE IN ('ESLC','P') THEN  S.SCRAP_PNL_QTY ELSE 0 END) AS BEHIND_EVA_SCRAP_QTY
      ,COUNT(DISTINCT (CASE WHEN S.SCRAP_TYPE = 'NGShip' THEN S.GLASS_ID 
                             WHEN S.SCRAP_TYPE = 'Scrap' AND S.SUB_PROD_TYPE NOT IN ('ESLC','P') THEN S.GLASS_ID
                            WHEN O.GLASS_ID IS NOT NULL THEN O.GLASS_ID ELSE NULL END))*E.SUBPRODUCTUNITQUANTITY1/2
       + COALESCE(SUM(P.BEHIND_EVA_PC_SY_QTY),0) AS BEHIND_EVA_SY_QTY
  FROM EVA_GLASS E
       LEFT JOIN DWT_SCRAP_GLS S
              ON E.GLASS_ID = S.GLASS_ID 
		     AND S.SCRAP_GLS_QTY + S.NGSHIP_GLS_QTY - S.UNSCRAP_GLS_QTY - S.NGUNSHIP_GLS_QTY > 0
		     AND S.DATE_TIMEKEY >= TO_CHAR('${dtStartDate}'::TIMESTAMP - INTERVAL '3 MONTH','YYYYMMDD')
		     AND S.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','') 
	   LEFT JOIN OLED_TP_SY_OUTOUT O
	          ON E.GLASS_ID = O.GLASS_ID 
		     AND O.SUB_PROD_TYPE NOT IN ('ESLC','P')
		LEFT JOIN PC_SY_OUTPUT P
		       ON E.GLASS_ID = P.GLASS_ID
 WHERE 1=1
 GROUP BY E.PROD_CODE
         ,E.SUB_PROD_ID
         ,E.EVA_QTY
         ,E.SUBPRODUCTUNITQUANTITY1]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
