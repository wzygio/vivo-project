<?xml version="1.0" encoding="UTF-8"?>
<WorkBook xmlVersion="20211223" releaseVersion="11.0.0">
<TableDataMap>
<TableData name="BATCH" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters>
<Parameter>
<Attributes name="dtEndDate"/>
<O>
<![CDATA[2025-09-04]]></O>
</Parameter>
<Parameter>
<Attributes name="cmcbProdCode"/>
<O>
<![CDATA[C441\',\'N236]]></O>
</Parameter>
<Parameter>
<Attributes name="dtStartDate"/>
<O>
<![CDATA[2025-07-04]]></O>
</Parameter>
</Parameters>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[WITH BATCH_INFO AS(
SELECT '批次' AS DATE_TYPE
      ,T2.LOT
      ,T1. GLASS_ID 
      ,S.PRODUCTCODE 
--      ,MIN(T1.DATE_TIMEKEY) AS DATE_TIMEKEY
  FROM (SELECT PRODUCTREQUESTNAME
            ,CASE WHEN D.CREATETIME > '2023-12-01 00:00:00' THEN TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'YY/MM/DD') ,'YY/MM/DD') ||'蒸镀批'
             ELSE '23/'||TO_CHAR(TO_DATE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_MATCHES(DESCRIPTION,'[0-9]A*/[0-9]A*蒸镀批')::VARCHAR,'蒸镀批',''),'{',''),'}',''),'MM/DD') ,'MM/DD') ||'蒸镀批'
             END  AS LOT
      FROM DWR_MES_PRODUCTREQUEST D
      WHERE D.SUBPRODUCTIONTYPE IN( 'ESLC','P')) T2
       LEFT JOIN DWT_INOUT_GLS T1
              ON T1.SUB_PROD_ID = T2.PRODUCTREQUESTNAME
             AND T1.OPER_CODE ='21200'
             AND INOUT_TYPE ='IN'
       LEFT JOIN DWR_MES_PRODUCTSPEC S
              ON T1.PROD_ID = S.PRODUCTSPECNAME 
 WHERE T1.SUB_PROD_TYPE IN ('ESLC','P','SLCFG','LCFG','SYZLC')
   AND T1.DATE_TIMEKEY >= TO_CHAR( '${dtStartDate}'::TIMESTAMP-INTERVAL '6 MONTH','YYYYMMDD')
   AND T1.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
   --AND T2.LOT IN ('05/08蒸镀批')
   --AND S.PRODUCTCODE='D36'
 GROUP BY T2.LOT
         ,T1.GLASS_ID 
         ,S.PRODUCTCODE
)
SELECT D.PROD_CODE||'-'||B.LOT AS N_LOT
      ,B.LOT AS LOT
      ,MIN(D.DATE_TIMEKEY) AS DATE_TIMEKEY
  FROM BATCH_INFO B
       INNER JOIN DWS_YLD_WAREHOUSING_D D
               ON B.GLASS_ID = D.GLASS_ID
 WHERE D.DATE_TIMEKEY >= REPLACE('${dtStartDate}','-','')
   AND D.DATE_TIMEKEY <= REPLACE('${dtEndDate}','-','')
 ${IF(LEN(cmcbProdCode)=0,"","AND D.PROD_CODE IN ('"+cmcbProdCode+"')")}
 GROUP BY D.PROD_CODE,D.PROD_CODE||'-'||B.LOT,B.LOT
 ORDER BY  D.PROD_CODE||'-'||B.LOT
          ,MIN(D.DATE_TIMEKEY)]]></Query>
<PageQuery>
<![CDATA[]]></PageQuery>
</TableData>
<TableData name="PRODUCTCODE" class="com.fr.data.impl.DBTableData">
<Desensitizations desensitizeOpen="false"/>
<Parameters/>
<Attributes maxMemRowCount="-1"/>
<Connection class="com.fr.data.impl.NameDatabaseConnection">
<DatabaseName>
<![CDATA[gp_conn]]></DatabaseName>
</Connection>
<Query>
<![CDATA[SELECT
    PRODUCT_CODE
FROM
    DWR_MES_PRODUCTSPEC_V
GROUP BY
    PRODUCT_CODE
ORDER BY
    PRODUCT_CODE]]></Query>
